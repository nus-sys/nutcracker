;; ============================================================================
;; Block 4: IPv4 Protocol Check (UDP) at Join Point
;; Valid on: DRMT, DPA, ARM
;; Dependencies: block0 AND block3 (complex join point)
;; Description: Checks if ipv4.protocol == 17 (UDP protocol)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 4 DRMT - Match key comparison for UDP
;; Pattern: match_key(ipv4.protocol, 17, exact)
;; Cost: 1 (struct_extract_ref) + 1 (read) + 1 (constant) + 2 (match_key) = 5
;; ----------------------------------------------------------------------------

;; Get reference to ipv4.protocol field at [1][7]
(let blk4_drmt_op0
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 7) (I32)))
        (bf3drmt_ref (bf3drmt_bool))))

;; Read the protocol field value
(let blk4_drmt_op1
    (bf3drmt_read blk4_drmt_op0 (I8)))

;; Create constant 17 (UDP protocol number)
(let blk4_drmt_op2
    (bf3drmt_constant 
        (NamedAttr "value" (IntegerAttr 17 (I8)))
        (I8)))

;; Match key: exact match for UDP protocol
(let blk4_drmt_op3
    (bf3drmt_match_key 
        blk4_drmt_op1
        blk4_drmt_op2
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk4_drmt_ops (vec-of blk4_drmt_op0 blk4_drmt_op1 blk4_drmt_op2 blk4_drmt_op3))

;; ----------------------------------------------------------------------------
;; Block 4 DPA - Comparison operation for UDP
;; Pattern: cmp(ipv4.protocol, 17, eq)
