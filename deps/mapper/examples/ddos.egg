;; ----------------------------------------------------------------------------
;; Block 4 ARM (LLVM) - Load and compare protocol field for UDP
;; Pattern: load ipv4.protocol; icmp eq, 17
;; Cost: 1 (constant 0) + 1 (constant 17) + 2 (gep) + 3 (load) + 2 (icmp) = 9
;; ----------------------------------------------------------------------------

;; Get packet pointer (Value 0)
(let blk4_cpu_op0 (Value 0 (llvm_ptr)))

;; Metadata pointer (Value 1)
(let blk4_cpu_op1 (Value 1 (llvm_ptr)))

;; Create constant 0 for GEP base
(let blk4_cpu_op2 
