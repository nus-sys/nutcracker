    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 7) (I32)))
        (bf3dpa_ref (bf3dpa_bool))))

;; Read the protocol field value
(let blk4_dpa_op1
    (bf3dpa_read blk4_dpa_op0 (I8)))

;; Create constant 17 (UDP protocol number)
(let blk4_dpa_op2
    (bf3dpa_constant 
        (NamedAttr "value" (IntegerAttr 17 (I8)))
        (I8)))

;; Compare: protocol == 17
(let blk4_dpa_op3
    (bf3dpa_cmp 
        blk4_dpa_op1
        blk4_dpa_op2
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

