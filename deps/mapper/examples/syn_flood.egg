        blk17_dpa_op3
        (NamedAttr "callee" (SymbolRefAttr "Counter::count"))))

(let blk17_dpa_ops (vec-of blk17_dpa_op0 blk17_dpa_op1 blk17_dpa_op2 blk17_dpa_op3 blk17_dpa_op4))

;; ----------------------------------------------------------------------------
;; Block 17 ARM (LLVM) - Counter increment via function call
;; Pattern: counter_count(&ack_count, metadata->hash_index)
;; Cost: 1 (alloca Counter) + 3 (load ptr) + 2 (gep hash_index) + 3 (load hash_index) + 5 (call) = 14
;; ----------------------------------------------------------------------------

;; Allocate Counter object (ack_count)
(let blk17_cpu_op0
    (llvm_alloca 
        (NamedAttr "callee" (SymbolRefAttr "Counter"))
        (llvm_ptr)))

;; Load metadata pointer
(let blk17_cpu_op1
    (llvm_load (Value 1 (llvm_ptr)) (llvm_ptr)))

;; Get pointer to metadata.hash_index (field index 0)
(let blk17_cpu_op2
    (llvm_getelementptr blk17_cpu_op1
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32)))
        (llvm_ptr)))

;; Load hash_index value
(let blk17_cpu_op3
    (llvm_load blk17_cpu_op2 (Int 32)))

;; Call counter_count(&ack_count, hash_index)
(let blk17_cpu_op4
    (llvm_call 
        (NamedAttr "callee" (SymbolRefAttr "counter_count"))
        blk17_cpu_op0
        blk17_cpu_op3
        (llvm_void)))

(let blk17_cpu_ops (vec-of blk17_cpu_op0 blk17_cpu_op1 blk17_cpu_op2 blk17_cpu_op3 blk17_cpu_op4))

;; ============================================================================
;; Block 17 Deployment Declarations
;; ============================================================================

(implement blk17_drmt DRMT (blk12) blk17_drmt_ops)
(implement blk17_dpa DPA (blk12) blk17_dpa_ops)
(implement blk17_cpu ARM (blk12) blk17_cpu_ops)

;; Block 17 Equivalences
(rewrite blk17_cpu blk17_drmt)
(rewrite blk17_cpu blk17_dpa)