;; ============================================================================
;; Hardware Configuration
;; ============================================================================

(hardware DRMT :cores 1 :sigma 0.0)
(hardware DPA :cores 8 :sigma 0.5)
(hardware ARM :cores 16 :sigma 1.0)

;; ============================================================================
;; Communication Links (BlueField-3 Topology)
;; ============================================================================

(link DRMT DPA 1.0 1.0)
(link DRMT ARM 1.0 1.0)
(link DPA ARM 0.5 0.5)

;; ============================================================================
;; Operation Definitions (with costs and types)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; BF3 DRMT Dialect Operations (Hardware Dataplane - SRAM/TCAM)
;; ----------------------------------------------------------------------------

(function bf3drmt_variable (Type) Type :cost 1 :type stateless)
(function bf3drmt_read (Type) Type :cost 1 :type stateless)
(function bf3drmt_assign (Type) Type :cost 1 :type stateful :sigma 0.1)
(function bf3drmt_struct_extract_ref (Type) Type :cost 1 :type stateless)
(function bf3drmt_constant (Type) Type :cost 1 :type stateless)
(function bf3drmt_cast (Type) Type :cost 1 :type stateless)
(function bf3drmt_match_key (Type Type Type Type) Type :cost 2 :type stateless)
(function bf3drmt_bool () Type :cost 1 :type stateless)
(function bf3drmt_valid_bit () Type :cost 1 :type stateless)
(function bf3drmt_bits (i64) Type :cost 1 :type stateless)
(function bf3drmt_ref (Type) Type :cost 1 :type stateless)
(function bf3drmt_struct (AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3drmt_header (AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3drmt_validity_bit (String Type) Attr :cost 1 :type stateless)

;; ----------------------------------------------------------------------------
;; BF3 DPA Dialect Operations (NPU - Programmable Dataplane)
;; ----------------------------------------------------------------------------

(function bf3dpa_variable (Type) Type :cost 8 :type stateless)
(function bf3dpa_read (Type) Type :cost 8 :type stateless)
(function bf3dpa_assign (Type) Type :cost 15 :type stateful :sigma 1.0)
(function bf3dpa_struct_extract_ref (Type) Type :cost 10 :type stateless)
(function bf3dpa_constant (Type) Type :cost 5 :type stateless)
(function bf3dpa_cast (Type) Type :cost 6 :type stateless)
(function bf3dpa_cmp (Type Type Type Type) Type :cost 12 :type stateless)
(function bf3dpa_if (Type Type) Type :cost 20 :type stateless)
(function bf3dpa_yield () Type :cost 2 :type stateless)
(function bf3dpa_bool () Type :cost 1 :type stateless)
(function bf3dpa_valid_bit () Type :cost 1 :type stateless)
(function bf3dpa_bits (i64) Type :cost 1 :type stateless)
(function bf3dpa_ref (Type) Type :cost 1 :type stateless)
(function bf3dpa_struct (AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3dpa_header (AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3dpa_validity_bit (String Type) Attr :cost 1 :type stateless)

;; ----------------------------------------------------------------------------
;; LLVM Dialect Operations (CPU/ARM)
;; ----------------------------------------------------------------------------

(function llvm_ptr () Type :cost 2 :type stateless)
(function llvm_mlir_constant (AttrPair Type) Op :cost 1 :type stateless)
(function llvm_load (Op Type) Op :cost 3 :type stateless)
(function llvm_getelementptr (Op AttrPair AttrPair Type) Op :cost 2 :type stateless)
(function llvm_icmp (Op Op AttrPair Type) Op :cost 2 :type stateless)
(function llvm_cond_br (Op AttrPair AttrPair) Op :cost 5 :type stateless)

;; ============================================================================
;; Block 1: IPv4 Header Validity Check
;; Valid on: DRMT, DPA, ARM
;; Dependencies: None (parser sets validity bit)
;; Description: Checks if IPv4 header is valid before processing
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 1 DRMT - Match on validity bit (exact match)
;; Pattern: if (hdr.ipv4.__valid == valid)
;; DRMT converts to: match_key(hdr.ipv4.__valid, valid_mask, exact)
;; Cost: 2 (read validity + match_key)
;; ----------------------------------------------------------------------------

;; Get reference to hdr.ipv4 (field index 1 of headers struct)
(let blk1_drmt_op0 
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3drmt_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3drmt_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3drmt_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "identification" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3drmt_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "res" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "window" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1)))))))))
        (NamedAttr "fieldIndex" (IntegerAttr 1 (I32)))
        (bf3drmt_ref (bf3drmt_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3drmt_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3drmt_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "identification" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3drmt_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 32)))))))

;; Get reference to hdr.ipv4.__valid (field index 13 - last field)
(let blk1_drmt_op1
    (bf3drmt_struct_extract_ref blk1_drmt_op0
        (NamedAttr "fieldIndex" (IntegerAttr 13 (I32)))
        (bf3drmt_ref (bf3drmt_valid_bit))))

;; Read validity bit value
(let blk1_drmt_op2 
    (bf3drmt_read blk1_drmt_op1 (bf3drmt_valid_bit)))

;; Create constant "valid"
(let blk1_drmt_op3
    (bf3drmt_constant 
        (NamedAttr "value" (bf3drmt_validity_bit "valid" (bf3drmt_valid_bit)))
        (bf3drmt_valid_bit)))

;; Match key: exact match on validity bit
(let blk1_drmt_op4
    (bf3drmt_match_key 
        blk1_drmt_op2
        blk1_drmt_op3
        (NamedAttr "match_kind" (StringAttr "exact"))
        (bf3drmt_bool)))

(let blk1_drmt_ops (vec-of blk1_drmt_op0 blk1_drmt_op1 blk1_drmt_op2 blk1_drmt_op3 blk1_drmt_op4))

;; ----------------------------------------------------------------------------
;; Block 1 DPA - Conditional branch on validity check
;; Pattern: if (hdr.ipv4.__valid == valid) { }
;; Cost: 8 (read) + 12 (cmp) + 20 (if) = 40
;; ----------------------------------------------------------------------------

;; Get reference to hdr.ipv4 (field index 1)
(let blk1_dpa_op0
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1)))))))))
        (NamedAttr "fieldIndex" (IntegerAttr 1 (I32)))
        (bf3dpa_ref (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32)))))))

;; Get reference to hdr.ipv4.__valid (field index 13)
(let blk1_dpa_op1
    (bf3dpa_struct_extract_ref blk1_dpa_op0
        (NamedAttr "fieldIndex" (IntegerAttr 13 (I32)))
        (bf3dpa_ref (bf3dpa_valid_bit))))

;; Read validity bit
(let blk1_dpa_op2
    (bf3dpa_read blk1_dpa_op1 (bf3dpa_valid_bit)))

;; Create constant "valid"
(let blk1_dpa_op3
    (bf3dpa_constant 
        (NamedAttr "value" (bf3dpa_validity_bit "valid" (bf3dpa_valid_bit)))
        (bf3dpa_valid_bit)))

;; Compare: __valid == valid
(let blk1_dpa_op4
    (bf3dpa_cmp blk1_dpa_op2 blk1_dpa_op3 
        (NamedAttr "kind" (IntegerAttr 5 (I32)))
        (bf3dpa_bool)))

;; If statement (empty body - just checks validity)
(let blk1_dpa_op5
    (bf3dpa_if blk1_dpa_op4 
        (Reg (vec-of (Blk (vec-of (bf3dpa_yield)))))))

(let blk1_dpa_ops (vec-of blk1_dpa_op0 blk1_dpa_op1 blk1_dpa_op2 blk1_dpa_op3 blk1_dpa_op4 blk1_dpa_op5))

;; ----------------------------------------------------------------------------
;; Block 1 ARM (LLVM) - Conditional branch on validity check
;; Pattern: if (hdr->ipv4.__valid == 1) { }
;; Cost: 2 (gep) + 2 (gep) + 3 (load) + 1 (const) + 2 (icmp) + 5 (br) = 15
;; ----------------------------------------------------------------------------

;; Get pointer to hdr.ipv4 (field index 1)
(let blk1_cpu_op0
    (llvm_getelementptr (Value 0 (llvm_ptr))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32)))
        (llvm_ptr)))

;; Get pointer to hdr.ipv4.__valid (field index 13)
(let blk1_cpu_op1
    (llvm_getelementptr blk1_cpu_op0
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 13) (I32)))
        (llvm_ptr)))

;; Load validity bit
(let blk1_cpu_op2
    (llvm_load blk1_cpu_op1 (I1)))

;; Create constant 1 (valid)
(let blk1_cpu_op3
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 1 (I1)))
        (I1)))

;; Compare: __valid == 1
(let blk1_cpu_op4
    (llvm_icmp blk1_cpu_op2 blk1_cpu_op3
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

;; Conditional branch
(let blk1_cpu_op5
    (llvm_cond_br blk1_cpu_op4
        (NamedAttr "trueDest" (UnitAttr))
        (NamedAttr "falseDest" (UnitAttr))))

(let blk1_cpu_ops (vec-of blk1_cpu_op0 blk1_cpu_op1 blk1_cpu_op2 blk1_cpu_op3 blk1_cpu_op4 blk1_cpu_op5))

;; ============================================================================
;; Block 1 Deployment Declarations
;; ============================================================================

(implement blk1_drmt DRMT () blk1_drmt_ops)
(implement blk1_dpa DPA () blk1_dpa_ops)
(implement blk1_cpu ARM () blk1_cpu_ops)

;; Block 16 Equivalences
(rewrite blk1_cpu blk1_drmt)
(rewrite blk1_cpu blk1_dpa)

;; ============================================================================
;; Block 2: TCP Header Validity Check
;; Valid on: DRMT, DPA, ARM
;; Dependencies: block1 (IPv4 must be valid first)
;; Description: Checks if TCP header is valid before SYN flood detection
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 2 DRMT - Match on TCP validity bit (exact match)
;; Pattern: if (hdr.tcp.__valid == valid)
;; DRMT converts to: match_key(hdr.tcp.__valid, valid_mask, exact)
;; Cost: 2 (read validity + match_key)
;; ----------------------------------------------------------------------------

;; Get reference to hdr.tcp (field index 2 of headers struct)
(let blk2_drmt_op0 
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3drmt_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3drmt_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3drmt_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "identification" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3drmt_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "res" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "window" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1)))))))))
        (NamedAttr "fieldIndex" (IntegerAttr 2 (I32)))
        (bf3drmt_ref (bf3drmt_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "res" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "window" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1)))))))

;; Get reference to hdr.tcp.__valid (field index 13 - last field)
(let blk2_drmt_op1
    (bf3drmt_struct_extract_ref blk2_drmt_op0
        (NamedAttr "fieldIndex" (IntegerAttr 13 (I32)))
        (bf3drmt_ref (bf3drmt_valid_bit))))

;; Read validity bit value
(let blk2_drmt_op2 
    (bf3drmt_read blk2_drmt_op1 (bf3drmt_valid_bit)))

;; Create constant "valid"
(let blk2_drmt_op3
    (bf3drmt_constant 
        (NamedAttr "value" (bf3drmt_validity_bit "valid" (bf3drmt_valid_bit)))
        (bf3drmt_valid_bit)))

;; Match key: exact match on validity bit
(let blk2_drmt_op4
    (bf3drmt_match_key 
        blk2_drmt_op2
        blk2_drmt_op3
        (NamedAttr "match_kind" (StringAttr "exact"))
        (bf3drmt_bool)))

(let blk2_drmt_ops (vec-of blk2_drmt_op0 blk2_drmt_op1 blk2_drmt_op2 blk2_drmt_op3 blk2_drmt_op4))

;; ----------------------------------------------------------------------------
;; Block 2 DPA - Conditional branch on TCP validity check
;; Pattern: if (hdr.tcp.__valid == valid) { }
;; Cost: 10 (struct_extract_ref) + 10 (struct_extract_ref) + 8 (read) + 5 (constant) + 12 (cmp) + 20 (if) = 65
;; ----------------------------------------------------------------------------

;; Get reference to hdr.tcp (field index 2)
(let blk2_dpa_op0
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1)))))))))
        (NamedAttr "fieldIndex" (IntegerAttr 2 (I32)))
