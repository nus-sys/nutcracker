            (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1)))))))))

;; Extract ipv4 header (field index 1)
(let blk18_dpa_op14
    (bf3dpa_struct_extract blk18_dpa_op13
        (NamedAttr "fieldIndex" (IntegerAttr 1 (I32)))
        (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32))))))

;; Extract protocol (field index 9)
(let blk18_dpa_op15
    (bf3dpa_struct_extract blk18_dpa_op14
        (NamedAttr "fieldIndex" (IntegerAttr 9 (I32)))
        (bf3dpa_bits 8)))

;; Call Hash::apply method
(let blk18_dpa_op16
    (bf3dpa_call_method 
        (Value 2 (bf3dpa_extern "Hash"))
        blk18_dpa_op0
        blk18_dpa_op3
        blk18_dpa_op6
        blk18_dpa_op9
        blk18_dpa_op12
        blk18_dpa_op15
        (NamedAttr "callee" (SymbolRefAttr "Hash::apply"))))

;; Read result from output variable
(let blk18_dpa_op17
    (bf3dpa_read blk18_dpa_op0 (bf3dpa_bits 32)))

;; Get reference to metadata.hash_index (field index 0)
(let blk18_dpa_op18
    (bf3dpa_struct_extract_ref 
        (Value 1 (bf3dpa_ref (bf3dpa_struct 
            (NamedAttr "name" (StringAttr "metadata"))
            (NamedAttr "hash_index" (TypeAttr (bf3dpa_bits 32)))
            (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 32)))
            (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 32))))))
        (NamedAttr "fieldIndex" (IntegerAttr 0 (I32)))
        (bf3dpa_ref (bf3dpa_bits 32))))

;; Assign result to metadata.hash_index
(let blk18_dpa_op19
    (bf3dpa_assign blk18_dpa_op17 blk18_dpa_op18))

(let blk18_dpa_ops (vec-of blk18_dpa_op0 blk18_dpa_op1 blk18_dpa_op2 blk18_dpa_op3 blk18_dpa_op4 blk18_dpa_op5 blk18_dpa_op6 blk18_dpa_op7 blk18_dpa_op8 blk18_dpa_op9 blk18_dpa_op10 blk18_dpa_op11 blk18_dpa_op12 blk18_dpa_op13 blk18_dpa_op14 blk18_dpa_op15 blk18_dpa_op16 blk18_dpa_op17 blk18_dpa_op18 blk18_dpa_op19))

;; ----------------------------------------------------------------------------
;; Block 18 ARM (LLVM) - Hash computation via function call
;; Pattern: hash_apply(hash_obj, &result, srcAddr, dstAddr, srcPort, dstPort)
;;          metadata.hash_index = result
;; Cost: 1 (alloca result) + 2+2+3 (gep+gep+load srcAddr) + 2+2+3 (gep+gep+load dstAddr) 
;;       + 2+2+3 (gep+gep+load srcPort) + 2+2+3 (gep+gep+load dstPort) + 5 (call) 
;;       + 1 (alloca) + 3 (load result) + 2 (gep hash_index) + 2 (store) = 42
;; ----------------------------------------------------------------------------

;; Allocate space for hash result (output parameter)
(let blk18_cpu_op0
    (llvm_alloca 
        (NamedAttr "alignment" (IntegerAttr 4 (I64)))
        (NamedAttr "init" (UnitAttr))
        (llvm_ptr)))

;; Get pointer to hdr.ipv4 (field index 1)
(let blk18_cpu_op1
    (llvm_getelementptr (Value 0 (llvm_ptr))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32)))
        (llvm_ptr)))

;; Get pointer to ipv4.srcAddr (field index 11)
(let blk18_cpu_op2
    (llvm_getelementptr blk18_cpu_op1
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 11) (I32)))
        (llvm_ptr)))

;; Load srcAddr value
(let blk18_cpu_op3
    (llvm_load blk18_cpu_op2 (Int 32)))

;; Get pointer to ipv4.dstAddr (field index 12)
(let blk18_cpu_op4
    (llvm_getelementptr blk18_cpu_op1
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 12) (I32)))
        (llvm_ptr)))

;; Load dstAddr value
(let blk18_cpu_op5
    (llvm_load blk18_cpu_op4 (Int 32)))

;; Get pointer to hdr.tcp (field index 2)
(let blk18_cpu_op6
    (llvm_getelementptr (Value 0 (llvm_ptr))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 2) (I32)))
        (llvm_ptr)))

;; Get pointer to tcp.srcPort (field index 0)
(let blk18_cpu_op7
    (llvm_getelementptr blk18_cpu_op6
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32)))
        (llvm_ptr)))

;; Load srcPort value
(let blk18_cpu_op8
    (llvm_load blk18_cpu_op7 (Int 16)))

;; Get pointer to tcp.dstPort (field index 1)
(let blk18_cpu_op9
    (llvm_getelementptr blk18_cpu_op6
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32)))
        (llvm_ptr)))

;; Load dstPort value
(let blk18_cpu_op10
    (llvm_load blk18_cpu_op9 (Int 16)))

;; Call hash_apply(hash_obj, &result, srcAddr, dstAddr, srcPort, dstPort)
(let blk18_cpu_op11
    (llvm_call 
        (NamedAttr "callee" (SymbolRefAttr "hash_apply"))
        (Value 2 (llvm_ptr))
        blk18_cpu_op0
        blk18_cpu_op3
        blk18_cpu_op5
        blk18_cpu_op8
        blk18_cpu_op10
        (llvm_void)))

;; Load hash result from output parameter
(let blk18_cpu_op12
    (llvm_load blk18_cpu_op0 (Int 32)))

;; Get pointer to metadata.hash_index (field index 0)
(let blk18_cpu_op13
    (llvm_getelementptr (Value 1 (llvm_ptr))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32)))
        (llvm_ptr)))

;; Store hash result to metadata.hash_index
(let blk18_cpu_op14
    (llvm_store blk18_cpu_op12 blk18_cpu_op13))

(let blk18_cpu_ops (vec-of blk18_cpu_op0 blk18_cpu_op1 blk18_cpu_op2 blk18_cpu_op3 blk18_cpu_op4 blk18_cpu_op5 blk18_cpu_op6 blk18_cpu_op7 blk18_cpu_op8 blk18_cpu_op9 blk18_cpu_op10 blk18_cpu_op11 blk18_cpu_op12 blk18_cpu_op13 blk18_cpu_op14))

;; ============================================================================
;; Block 18 Deployment Declarations
;; ============================================================================

(implement blk18_drmt DRMT (blk10) blk18_drmt_ops)
(implement blk18_dpa DPA (blk10) blk18_dpa_ops)
(implement blk18_cpu ARM (blk10) blk18_cpu_ops)

;; Block 18 Equivalences
(rewrite blk18_cpu blk18_drmt)
(rewrite blk18_cpu blk18_dpa)

;; ============================================================================
;; Block 5: TCP SYN Flag Check (SYN=1, ACK=0) - After Hash Computation
;; Valid on: DRMT, DPA, ARM
;; Dependencies: block10 (flow match) AND block18 (hash computed)
;; Description: Checks if (tcp.flags & 2) == 2 (SYN flag set) after hash is ready
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 5 DRMT - Ternary match on TCP flags field
;; Pattern: if ((tcp.flags & 2) == 2)
;; DRMT converts to: match_key(tcp.flags, mask=2, ternary)
;; Cost: 1 (struct_extract_ref tcp) + 1 (struct_extract_ref flags) + 1 (read) + 1 (constant) + 2 (match_key) = 6
;; ----------------------------------------------------------------------------

;; Get reference to hdr.tcp (field index 2 of headers struct)
(let blk5_drmt_op0 
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3drmt_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3drmt_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3drmt_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "identification" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3drmt_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3drmt_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3drmt_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "res" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "window" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1)))))))))
        (NamedAttr "fieldIndex" (IntegerAttr 2 (I32)))
        (bf3drmt_ref (bf3drmt_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "res" (TypeAttr (bf3drmt_bits 4))) (NamedAttr "flags" (TypeAttr (bf3drmt_bits 8))) (NamedAttr "window" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3drmt_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3drmt_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3drmt_bits 1)))))))

;; Get reference to tcp.flags (field index 6)
(let blk5_drmt_op1
    (bf3drmt_struct_extract_ref blk5_drmt_op0
        (NamedAttr "fieldIndex" (IntegerAttr 6 (I32)))
        (bf3drmt_ref (bf3drmt_bits 8))))

;; Read flags value
(let blk5_drmt_op2 
    (bf3drmt_read blk5_drmt_op1 (bf3drmt_bits 8)))

;; Create constant 2 (SYN flag mask)
(let blk5_drmt_op3
    (bf3drmt_constant 
        (NamedAttr "value" (bf3drmt_int 2 (bf3drmt_bits 8)))
        (bf3drmt_bits 8)))

;; Match key: ternary match on flags field with mask 2
(let blk5_drmt_op4
    (bf3drmt_match_key 
        blk5_drmt_op2
        blk5_drmt_op3
        (NamedAttr "match_kind" (StringAttr "ternary"))
        (bf3drmt_bits 8)))

(let blk5_drmt_ops (vec-of blk5_drmt_op0 blk5_drmt_op1 blk5_drmt_op2 blk5_drmt_op3 blk5_drmt_op4))

;; ----------------------------------------------------------------------------
;; Block 5 DPA - Bitwise AND and comparison
;; Pattern: if ((tcp.flags & 2) == 2) { }
;; Cost: 8 (read) + 10 (struct_extract tcp) + 10 (struct_extract flags) + 5 (constant 2 mask) + 12 (binop AND) + 5 (constant 2 expected) + 6 (cast) + 12 (cmp) + 20 (if) = 88
;; ----------------------------------------------------------------------------

;; Read headers struct
(let blk5_dpa_op0
    (bf3dpa_read 
        (Value 0 (bf3dpa_ref (bf3dpa_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1)))))))))
        (bf3dpa_struct 
            (NamedAttr "name" (StringAttr "headers"))
            (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1))))))
            (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32))))))
            (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1)))))))))

;; Extract tcp header from headers (field index 2)
(let blk5_dpa_op1
    (bf3dpa_struct_extract blk5_dpa_op0
        (NamedAttr "fieldIndex" (IntegerAttr 2 (I32)))
        (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))))))

;; Extract flags field from tcp (field index 6)
(let blk5_dpa_op2
    (bf3dpa_struct_extract blk5_dpa_op1
        (NamedAttr "fieldIndex" (IntegerAttr 6 (I32)))
        (bf3dpa_bits 8)))

;; Create constant 2 (SYN flag mask)
(let blk5_dpa_op3
    (bf3dpa_constant 
        (NamedAttr "value" (bf3dpa_int 2 (bf3dpa_bits 8)))
        (bf3dpa_bits 8)))

;; Bitwise AND: flags & 2 (kind 10 = AND)
(let blk5_dpa_op4
    (bf3dpa_binop blk5_dpa_op2 blk5_dpa_op3 
        (NamedAttr "kind" (IntegerAttr 10 (I32)))
        (bf3dpa_bits 8)))

;; Create constant 2 (expected value, 64-bit infint)
(let blk5_dpa_op5
    (bf3dpa_constant 
        (NamedAttr "value" (bf3dpa_int 2 (bf3dpa_bits 64)))
        (bf3dpa_bits 64)))

;; Cast expected value to 8-bit
(let blk5_dpa_op6
    (bf3dpa_cast blk5_dpa_op5 (bf3dpa_bits 8)))

;; Compare: (flags & 2) == 2 (kind 5 = eq)
(let blk5_dpa_op7
    (bf3dpa_cmp blk5_dpa_op4 blk5_dpa_op6 
        (NamedAttr "kind" (IntegerAttr 5 (I32)))
        (bf3dpa_bool)))

;; If statement (empty body)
(let blk5_dpa_op8
    (bf3dpa_if blk5_dpa_op7 
        (Reg (vec-of (Blk (vec-of (bf3dpa_yield)))))))

(let blk5_dpa_ops (vec-of blk5_dpa_op0 blk5_dpa_op1 blk5_dpa_op2 blk5_dpa_op3 blk5_dpa_op4 blk5_dpa_op5 blk5_dpa_op6 blk5_dpa_op7 blk5_dpa_op8))

;; ----------------------------------------------------------------------------
;; Block 5 ARM (LLVM) - Bitwise AND and comparison
;; Pattern: if ((tcp->flags & 2) == 2) { }
