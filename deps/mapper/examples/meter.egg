;; Value 5 marker (UDP destination port stored)
(let blk7_cpu_op5 (Value 5 (None)))

(let blk7_cpu_ops (vec-of blk7_cpu_op0 blk7_cpu_op1 blk7_cpu_op2 blk7_cpu_op3 blk7_cpu_op4 blk7_cpu_op5))

;; ============================================================================
;; Block 7 Deployment Declarations
;; ============================================================================

(implement blk7_drmt DRMT (blk15) blk7_drmt_ops)
