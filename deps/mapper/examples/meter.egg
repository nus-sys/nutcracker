;; ----------------------------------------------------------------------------
;; Block 7 DPA - Read UDP destination port field
;; Pattern: read(packet.udp.dstPort)
;; Cost: 10 (struct_extract_ref) + 8 (read) = 18
;; ----------------------------------------------------------------------------

;; Get reference to UDP dstPort field at [3][1]
(let blk7_dpa_op0
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 3 1) (I32)))
        (bf3dpa_ref (bf3dpa_bool))))

;; Read the UDP destination port field value
(let blk7_dpa_op1
    (bf3dpa_read blk7_dpa_op0 (I16)))

(let blk7_dpa_ops (vec-of blk7_dpa_op0 blk7_dpa_op1))

;; ----------------------------------------------------------------------------
;; Block 7 ARM (LLVM) - Load UDP destination port field
;; Pattern: load packet.udp.dstPort
;; Cost: 1 (constant 0) + 2 (gep) + 3 (load) = 6
;; ----------------------------------------------------------------------------

;; Get packet pointer (Value 0)
(let blk7_cpu_op0 (Value 0 (llvm_ptr)))

;; Metadata pointer (Value 1) - not used but declared
(let blk7_cpu_op1 (Value 1 (llvm_ptr)))

;; Create constant 0 for GEP base
(let blk7_cpu_op2 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 0 (I64)))
        (I64)))

;; GEP to UDP dstPort at [0, 3, 1] (struct index 3 = udp, field 1 = dstPort)
(let blk7_cpu_op3 
    (llvm_getelementptr blk7_cpu_op0 blk7_cpu_op2
        (NamedAttr "elem_type" (TypeAttr (llvm_struct "struct.packet" 
            (llvm_struct "struct.ethernet" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16))
            (llvm_struct "struct.ipv4" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16) (I32) (I32) (I32) (I32))
            (llvm_struct "struct.tcp" (I16) (I16) (I32) (I32) (I8) (I8) (I16) (I16) (I16) (I32) (I32) (I32) (I32))
            (llvm_struct "struct.udp" (I16) (I16) (I16) (I16) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32))
            (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32))))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 3 1) (I32)))
        (llvm_ptr)))

;; Load UDP destination port field value
(let blk7_cpu_op4 
