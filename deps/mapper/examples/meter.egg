;; ----------------------------------------------------------------------------
;; Block 17 DPA - NOT SUPPORTED
;; DPA does not have metering capability
;; This block cannot be deployed to DPA
;; ----------------------------------------------------------------------------

;; No DPA implementation - metering not supported

;; ----------------------------------------------------------------------------
;; Block 17 ARM (LLVM) - Call meter_execute function with index 0
;; Pattern: meter_execute(0)
;; Cost: 1 (constant) + 5 (call) = 6
;; ----------------------------------------------------------------------------

;; Packet pointer (Value 0)
(let blk17_cpu_op0 (Value 0 (llvm_ptr)))

;; Metadata pointer (Value 1)
(let blk17_cpu_op1 (Value 1 (llvm_ptr)))

;; Create constant 0 (meter index 0)
(let blk17_cpu_op2 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 0 (I32)))
        (I32)))

;; Call meter_execute function
(let blk17_cpu_op3 
    (llvm_call blk17_cpu_op2
        (NamedAttr "CConv" (StringAttr "ccc"))
        (NamedAttr "CConv" (StringAttr "ccc"))
        (NamedAttr "callee" (SymbolRefAttr "meter_execute"))
        (I32)))

;; Value 4 marker (meter result stored)
(let blk17_cpu_op4 (Value 4 (None)))

(let blk17_cpu_ops (vec-of blk17_cpu_op0 blk17_cpu_op1 blk17_cpu_op2 blk17_cpu_op3 blk17_cpu_op4))

;; ============================================================================
;; Block 17 Deployment Declarations
;; ============================================================================

(implement blk17_drmt DRMT (blk7) blk17_drmt_ops)
;; NO DPA IMPLEMENTATION - metering not supported on DPA
