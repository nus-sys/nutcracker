;; ============================================================================
;; Block 17: Meter Execution (Instance 0, UDP path)
;; Valid on: DRMT, ARM (NOT DPA - no metering support)
;; Dependencies: block7 (UDP destination port read)
;; Description: Executes meter instance 0 on UDP path
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 17 DRMT - Meter call_method with index 0
;; Pattern: meter.execute(0)
;; Cost: 1 (constant) + 5 (call_method) = 6
;; Note: DRMT representation appears to be missing the constant operand
;; ----------------------------------------------------------------------------

;; Create constant 0 (meter index 0)
(let blk17_drmt_op0
    (bf3drmt_constant 
        (NamedAttr "value" (IntegerAttr 0 (I32)))
        (I32)))

