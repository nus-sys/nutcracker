(rewrite blk17_cpu blk17_drmt)

;; ============================================================================
;; Block 13: Per-Entry Counter
;; Valid on: DRMT, ARM (possibly DPA with extern support)
;; Dependencies: block3 (TCP/UDP destination port read)
;; Description: Increments per-entry counter (likely indexed by port)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 13 DRMT - Counter call_method
;; Pattern: counter.count()
;; Cost: 5 (call_method)
;; Note: DRMT representation appears to be missing operands
;; ----------------------------------------------------------------------------

;; Call counter method (per-entry counting)
(let blk13_drmt_op0
    (bf3drmt_call_method 
        (NamedAttr "CConv" (OpaqueAttr "#llvm.cconv<ccc>" "llvm.cconv"))
        (I32)))

(let blk13_drmt_ops (vec-of blk13_drmt_op0))

;; ----------------------------------------------------------------------------
;; Block 13 DPA - Conditional support (if extern counter available)
;; Pattern: extern counter.count()
;; Cost: 50 (call_method for extern)
;; Note: May not be supported depending on DPA extern configuration
;; ----------------------------------------------------------------------------

;; Call counter method via extern
(let blk13_dpa_op0
    (bf3dpa_call_method 
        (NamedAttr "CConv" (OpaqueAttr "#llvm.cconv<ccc>" "llvm.cconv"))))

(let blk13_dpa_ops (vec-of blk13_dpa_op0))

;; ----------------------------------------------------------------------------
;; Block 13 ARM (LLVM) - Call per_entry_counter function
;; Pattern: per_entry_counter()
;; Cost: 5 (call with tail call optimization)
;; ----------------------------------------------------------------------------

;; Packet pointer (Value 0)
(let blk13_cpu_op0 (Value 0 (llvm_ptr)))

;; Metadata pointer (Value 1)
(let blk13_cpu_op1 (Value 1 (llvm_ptr)))

;; Call per_entry_counter function (tail call)
(let blk13_cpu_op2 
    (llvm_call_1
        (NamedAttr "CConv" (StringAttr "ccc"))
        (NamedAttr "TailCallKind" (StringAttr "tail"))
        (NamedAttr "callee" (SymbolRefAttr "per_entry_counter"))
        (I32)))

;; Value 3 marker (counter result stored)
(let blk13_cpu_op3 (Value 3 (None)))

(let blk13_cpu_ops (vec-of blk13_cpu_op0 blk13_cpu_op1 blk13_cpu_op2 blk13_cpu_op3))

;; ============================================================================
;; Block 13 Deployment Declarations
;; ============================================================================

(implement blk13_drmt DRMT (blk3) blk13_drmt_ops)
(implement blk13_cpu ARM (blk3) blk13_cpu_ops)

;; Block 13 Equivalences
(rewrite blk13_cpu blk13_drmt)