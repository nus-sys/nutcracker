(rewrite blk8_cpu blk8_dpa)

;; ============================================================================
;; Block 13: Hash Computation for Bloom Filter
;; Valid on: DRMT, DPA, ARM
;; Dependencies: blk8
;; Description: Extracts srcAddr from IPv4 header, computes hash, generates counter position
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 13 CPU (LLVM) - Hash computation using multiplication
;; ----------------------------------------------------------------------------

;; Declare local variables (alloca)
(let blk13_cpu_op0 (llvm_alloca (NamedAttr "init" (UnitAttr)) (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))  ;; counter_val
(let blk13_cpu_op1 (llvm_alloca (NamedAttr "init" (UnitAttr)) (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))  ;; srcIp
(let blk13_cpu_op2 (llvm_alloca (NamedAttr "init" (UnitAttr)) (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))  ;; MULT_HASH_A
(let blk13_cpu_op3 (llvm_alloca (NamedAttr "init" (UnitAttr)) (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))  ;; hash_val
(let blk13_cpu_op4 (llvm_alloca (NamedAttr "init" (UnitAttr)) (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))  ;; counter_pos
(let blk13_cpu_op5 (Value 0 (llvm_ptr)))
(let blk13_cpu_op6 (llvm_load blk13_cpu_op5 (llvm_struct "headers" (llvm_struct "ethernet_t") (llvm_struct "ipv4_t") (llvm_struct "tcp_t"))))
(let blk13_cpu_op7 (llvm_getelementptr blk13_cpu_op5 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32))) (llvm_ptr)))
