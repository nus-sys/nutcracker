;; Extract srcAddr from headers.ipv4.srcAddr
(let blk13_dpa_op5 (Value 0 (bf3dpa_ref (bf3dpa_struct (NamedAttr "name" (StringAttr "headers")) (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1)))))) (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32)))))) (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))))))))))
(let blk13_dpa_op6 (bf3dpa_read blk13_dpa_op5 (bf3dpa_struct)))
(let blk13_dpa_op7 (bf3dpa_struct_extract blk13_dpa_op6 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3dpa_header)))
(let blk13_dpa_op8 (bf3dpa_struct_extract blk13_dpa_op7 (NamedAttr "fieldIndex" (IntegerAttr 11 (I32))) (bf3dpa_bits 32)))
(let blk13_dpa_op9 (bf3dpa_assign blk13_dpa_op8 blk13_dpa_op1))  ;; srcIp = headers.ipv4.srcAddr

;; Initialize MULT_HASH_A = 1234
(let blk13_dpa_op10 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 1234 (bf3dpa_bits 32))) (bf3dpa_bits 32)))
(let blk13_dpa_op11 (bf3dpa_cast blk13_dpa_op10 (bf3dpa_bits 32)))
(let blk13_dpa_op12 (bf3dpa_assign blk13_dpa_op11 blk13_dpa_op2))

;; Compute hash: hash_val = (srcIp * MULT_HASH_A) >> 20
(let blk13_dpa_op13 (bf3dpa_read blk13_dpa_op1 (bf3dpa_bits 32)))  ;; Read srcIp
(let blk13_dpa_op14 (bf3dpa_read blk13_dpa_op2 (bf3dpa_bits 32)))  ;; Read MULT_HASH_A
(let blk13_dpa_op15 (bf3dpa_binop blk13_dpa_op13 blk13_dpa_op14 (NamedAttr "kind" (IntegerAttr 1 (I32))) (bf3dpa_bits 32)))
(let blk13_dpa_op16 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 20 (bf3dpa_bits 16))) (bf3dpa_bits 16)))
(let blk13_dpa_op17 (bf3dpa_shr blk13_dpa_op15 blk13_dpa_op16 (bf3dpa_bits 32)))  ;; >> 20
(let blk13_dpa_op18 (bf3dpa_assign blk13_dpa_op17 blk13_dpa_op3))

;; Compute counter_pos = hash_val & 4095
(let blk13_dpa_op19 (bf3dpa_read blk13_dpa_op3 (bf3dpa_bits 32)))  ;; Read hash_val
(let blk13_dpa_op20 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 4095 (bf3dpa_bits 32))) (bf3dpa_bits 32)))
(let blk13_dpa_op21 (bf3dpa_binop blk13_dpa_op19 blk13_dpa_op20 (NamedAttr "kind" (IntegerAttr 10 (I32))) (bf3dpa_bits 32)))
(let blk13_dpa_op22 (bf3dpa_assign blk13_dpa_op21 blk13_dpa_op4))

(let blk13_dpa_ops (vec-of blk13_dpa_op0 blk13_dpa_op1 blk13_dpa_op2 blk13_dpa_op3 blk13_dpa_op4 blk13_dpa_op5 blk13_dpa_op6 blk13_dpa_op7 blk13_dpa_op8 blk13_dpa_op9 blk13_dpa_op10 blk13_dpa_op11 blk13_dpa_op12 blk13_dpa_op13 blk13_dpa_op14 blk13_dpa_op15 blk13_dpa_op16 blk13_dpa_op17 blk13_dpa_op18 blk13_dpa_op19 blk13_dpa_op20 blk13_dpa_op21 blk13_dpa_op22))

;; ----------------------------------------------------------------------------
;; Block 13 DRMT - Hash computation using shifts (hardware-friendly)
;; ----------------------------------------------------------------------------

;; Declare variables
(let blk13_drmt_op0 (bf3drmt_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_val")) (bf3drmt_ref (bf3drmt_bits 16))))
(let blk13_drmt_op1 (bf3drmt_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "srcIp")) (bf3drmt_ref (bf3drmt_bits 32))))
(let blk13_drmt_op2 (bf3drmt_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "MULT_HASH_A")) (bf3drmt_ref (bf3drmt_bits 32))))
(let blk13_drmt_op3 (bf3drmt_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "hash_val")) (bf3drmt_ref (bf3drmt_bits 32))))
(let blk13_drmt_op4 (bf3drmt_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_pos")) (bf3drmt_ref (bf3drmt_bits 32))))

;; Extract srcAddr from headers.ipv4.srcAddr
(let blk13_drmt_op5 (Value 0 (bf3drmt_ref (bf3drmt_struct (NamedAttr "name" (StringAttr "headers")) (NamedAttr "ethernet" (TypeAttr (bf3drmt_header))) (NamedAttr "ipv4" (TypeAttr (bf3drmt_header))) (NamedAttr "tcp" (TypeAttr (bf3drmt_header)))))))
(let blk13_drmt_op6 (bf3drmt_struct_extract_ref blk13_drmt_op5 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3drmt_ref (bf3drmt_header))))
(let blk13_drmt_op7 (bf3drmt_struct_extract_ref blk13_drmt_op6 (NamedAttr "fieldIndex" (IntegerAttr 11 (I32))) (bf3drmt_ref (bf3drmt_bits 32))))
(let blk13_drmt_op8 (bf3drmt_read blk13_drmt_op7 (bf3drmt_bits 32)))
(let blk13_drmt_op9 (bf3drmt_assign blk13_drmt_op8 blk13_drmt_op1))  ;; srcIp = headers.ipv4.srcAddr

;; Initialize MULT_HASH_A = 73 (using shift-add approximation)
(let blk13_drmt_op10 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 73 (bf3drmt_bits 32))) (bf3drmt_bits 32)))
(let blk13_drmt_op11 (bf3drmt_cast blk13_drmt_op10 (bf3drmt_bits 32)))
(let blk13_drmt_op12 (bf3drmt_assign blk13_drmt_op11 blk13_drmt_op2))

;; Compute hash using shift-add: hash = ((srcIp << 6) + (srcIp << 3) + srcIp) >> 20
(let blk13_drmt_op13 (bf3drmt_read blk13_drmt_op1 (bf3drmt_bits 32)))  ;; Read srcIp
(let blk13_drmt_op14 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 6 (bf3drmt_bits 32))) (bf3drmt_bits 32)))
(let blk13_drmt_op15 (bf3drmt_shl blk13_drmt_op13 blk13_drmt_op14 (bf3drmt_bits 32)))  ;; srcIp << 6
(let blk13_drmt_op16 (bf3drmt_read blk13_drmt_op1 (bf3drmt_bits 32)))
(let blk13_drmt_op17 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 3 (bf3drmt_bits 32))) (bf3drmt_bits 32)))
(let blk13_drmt_op18 (bf3drmt_shl blk13_drmt_op16 blk13_drmt_op17 (bf3drmt_bits 32)))  ;; srcIp << 3
(let blk13_drmt_op19 (bf3drmt_binop blk13_drmt_op15 blk13_drmt_op18 (NamedAttr "kind" (IntegerAttr 4 (I32))) (bf3drmt_bits 32)))  ;; +
(let blk13_drmt_op20 (bf3drmt_read blk13_drmt_op1 (bf3drmt_bits 32)))
(let blk13_drmt_op21 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 0 (bf3drmt_bits 32))) (bf3drmt_bits 32)))
(let blk13_drmt_op22 (bf3drmt_shl blk13_drmt_op20 blk13_drmt_op21 (bf3drmt_bits 32)))  ;; srcIp << 0 (identity)
(let blk13_drmt_op23 (bf3drmt_binop blk13_drmt_op19 blk13_drmt_op22 (NamedAttr "kind" (IntegerAttr 4 (I32))) (bf3drmt_bits 32)))  ;; +
(let blk13_drmt_op24 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 20 (bf3drmt_bits 16))) (bf3drmt_bits 16)))
(let blk13_drmt_op25 (bf3drmt_shr blk13_drmt_op23 blk13_drmt_op24 (bf3drmt_bits 32)))  ;; >> 20
(let blk13_drmt_op26 (bf3drmt_assign blk13_drmt_op25 blk13_drmt_op3))

;; Compute counter_pos = hash_val[11:0] (slice bits 0-11)
(let blk13_drmt_op27 (bf3drmt_read blk13_drmt_op3 (bf3drmt_bits 32)))
(let blk13_drmt_op28 (bf3drmt_slice blk13_drmt_op27 (NamedAttr "highBit" (IntegerAttr 11 (I32))) (NamedAttr "lowBit" (IntegerAttr 0 (I32))) (bf3drmt_bits 32)))
(let blk13_drmt_op29 (bf3drmt_assign blk13_drmt_op28 blk13_drmt_op4))

(let blk13_drmt_ops (vec-of blk13_drmt_op0 blk13_drmt_op1 blk13_drmt_op2 blk13_drmt_op3 blk13_drmt_op4 blk13_drmt_op5 blk13_drmt_op6 blk13_drmt_op7 blk13_drmt_op8 blk13_drmt_op9 blk13_drmt_op10 blk13_drmt_op11 blk13_drmt_op12 blk13_drmt_op13 blk13_drmt_op14 blk13_drmt_op15 blk13_drmt_op16 blk13_drmt_op17 blk13_drmt_op18 blk13_drmt_op19 blk13_drmt_op20 blk13_drmt_op21 blk13_drmt_op22 blk13_drmt_op23 blk13_drmt_op24 blk13_drmt_op25 blk13_drmt_op26 blk13_drmt_op27 blk13_drmt_op28 blk13_drmt_op29))

;; ----------------------------------------------------------------------------
;; Block 13 Implementations
;; ----------------------------------------------------------------------------

(implement blk13_drmt DRMT (blk8) blk13_drmt_ops)
(implement blk13_dpa DPA (blk8) blk13_dpa_ops)
(implement blk13_cpu ARM (blk8) blk13_cpu_ops)

;; Block 13 Equivalences
(rewrite blk13_cpu blk13_drmt)
(rewrite blk13_cpu blk13_dpa)

;; ============================================================================
;; Block 14: Register Read from Bloom Filter
;; Valid on: DPA, ARM (NOT on DRMT - no register support)
;; Dependencies: blk13 (uses counter_pos computed in blk13)
;; Description: Reads value from bloom filter register at computed position
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 14 CPU (LLVM) - Register operations via function calls
;; ----------------------------------------------------------------------------

;; Create register with size 4096
(let blk14_cpu_op0 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 4096 (Int 32))) (Int 32)))
(let blk14_cpu_op1 (llvm_call (NamedAttr "callee" (SymbolRefAttr "register_create")) blk14_cpu_op0 (llvm_ptr)))

;; Allocate space for output value
(let blk14_cpu_op2 (llvm_alloca (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))

;; Allocate space for counter_pos (index)
(let blk14_cpu_op3 (llvm_alloca (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))
(let blk14_cpu_op4 (llvm_load blk14_cpu_op3 (Int 32)))

;; Call register_read(register, &value_out, counter_pos)
(let blk14_cpu_op5 (llvm_call_void (NamedAttr "callee" (SymbolRefAttr "register_read")) blk14_cpu_op1 blk14_cpu_op2 blk14_cpu_op4))

;; Allocate counter_val
(let blk14_cpu_op6 (llvm_alloca (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))

;; Load value from value_out
(let blk14_cpu_op7 (llvm_load blk14_cpu_op2 (Int 16)))

;; Store to counter_val
(let blk14_cpu_op8 (llvm_store blk14_cpu_op7 blk14_cpu_op6))

(let blk14_cpu_ops (vec-of blk14_cpu_op0 blk14_cpu_op1 blk14_cpu_op2 blk14_cpu_op3 blk14_cpu_op4 blk14_cpu_op5 blk14_cpu_op6 blk14_cpu_op7 blk14_cpu_op8))

;; ----------------------------------------------------------------------------
;; Block 14 DPA - Register operations via call_method
;; ----------------------------------------------------------------------------

;; Declare variables
(let blk14_dpa_op0 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_val")) (bf3dpa_ref (bf3dpa_bits 16))))
(let blk14_dpa_op1 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "value_out_arg")) (bf3dpa_ref (bf3dpa_bits 16))))
(let blk14_dpa_op2 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_pos")) (bf3dpa_ref (bf3dpa_bits 32))))

;; Instantiate Register<16, 32> with size 4096
(let blk14_dpa_op3 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 4096 (bf3dpa_bits 32))) (bf3dpa_bits 32)))
(let blk14_dpa_op4 (bf3dpa_instantiate blk14_dpa_op3 
                        (NamedAttr "callee" (SymbolRefAttr "Register")) 
                        (NamedAttr "name" (StringAttr "bloom_filter")) 
                        (bf3dpa_extern "Register" (bf3dpa_bits 16) (bf3dpa_bits 32))))

;; Read counter_pos value
(let blk14_dpa_op5 (bf3dpa_read blk14_dpa_op2 (bf3dpa_bits 32)))

;; Call Register::read(bloom_filter, value_out_arg, counter_pos)
(let blk14_dpa_op6 (bf3dpa_call_method blk14_dpa_op4 blk14_dpa_op1 blk14_dpa_op5 
                        (NamedAttr "callee" (SymbolRefAttr "Register::read"))))

;; Read value from value_out_arg
(let blk14_dpa_op7 (bf3dpa_read blk14_dpa_op1 (bf3dpa_bits 16)))

;; Assign to counter_val
(let blk14_dpa_op8 (bf3dpa_assign blk14_dpa_op7 blk14_dpa_op0))

(let blk14_dpa_ops (vec-of blk14_dpa_op0 blk14_dpa_op1 blk14_dpa_op2 blk14_dpa_op3 blk14_dpa_op4 blk14_dpa_op5 blk14_dpa_op6 blk14_dpa_op7 blk14_dpa_op8))

;; ----------------------------------------------------------------------------
;; Block 14 Implementations - ONLY DPA and ARM (no DRMT)
;; ----------------------------------------------------------------------------

(implement blk14_dpa DPA (blk13) blk14_dpa_ops)
(implement blk14_cpu ARM (blk13) blk14_cpu_ops)

;; Block 14 Equivalences - only between DPA and ARM
(rewrite blk14_cpu blk14_dpa)

;; ============================================================================
;; Block 15: Register Write to Bloom Filter
;; Valid on: DPA, ARM (NOT on DRMT - no register support)
;; Dependencies: blk14 (writes computed value to bloom filter)
;; Description: Writes value 0 to bloom filter register at counter_pos
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 15 CPU (LLVM) - Register write via function call
;; ----------------------------------------------------------------------------

;; Allocate counter_val variable
(let blk15_cpu_op0 (llvm_alloca (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))

;; Create register with size 4096
(let blk15_cpu_op1 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 4096 (Int 32))) (Int 32)))
(let blk15_cpu_op2 (llvm_call (NamedAttr "callee" (SymbolRefAttr "register_create")) blk15_cpu_op1 (llvm_ptr)))

;; Allocate and load counter_pos
(let blk15_cpu_op3 (llvm_alloca (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))
(let blk15_cpu_op4 (llvm_load blk15_cpu_op3 (Int 32)))

;; Create constant 0 to write
(let blk15_cpu_op5 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 0 (I64))) (I64)))

;; Call Register::write(register, counter_pos, 0)
(let blk15_cpu_op6 (llvm_call_void (NamedAttr "callee" (SymbolRefAttr "Register::write")) blk15_cpu_op2 blk15_cpu_op4 blk15_cpu_op5))

(let blk15_cpu_ops (vec-of blk15_cpu_op0 blk15_cpu_op1 blk15_cpu_op2 blk15_cpu_op3 blk15_cpu_op4 blk15_cpu_op5 blk15_cpu_op6))

;; ----------------------------------------------------------------------------
;; Block 15 DPA - Register write via call_method
;; ----------------------------------------------------------------------------

;; Declare variables
(let blk15_dpa_op0 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_val")) (bf3dpa_ref (bf3dpa_bits 16))))
(let blk15_dpa_op1 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_pos")) (bf3dpa_ref (bf3dpa_bits 32))))

;; Instantiate Register<16, 32> with size 4096
(let blk15_dpa_op2 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 4096 (bf3dpa_bits 32))) (bf3dpa_bits 32)))
(let blk15_dpa_op3 (bf3dpa_instantiate blk15_dpa_op2 
                        (NamedAttr "callee" (SymbolRefAttr "Register")) 
                        (NamedAttr "name" (StringAttr "bloom_filter")) 
                        (bf3dpa_extern "Register" (bf3dpa_bits 16) (bf3dpa_bits 32))))

;; Read counter_pos value
(let blk15_dpa_op4 (bf3dpa_read blk15_dpa_op1 (bf3dpa_bits 32)))

;; Create constant 0 value to write
(let blk15_dpa_op5 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 0 (bf3dpa_bits 32))) (bf3dpa_bits 32)))
(let blk15_dpa_op6 (bf3dpa_cast blk15_dpa_op5 (bf3dpa_bits 16)))

;; Call Register::write(bloom_filter, counter_pos, 0)
(let blk15_dpa_op7 (bf3dpa_call_method blk15_dpa_op3 blk15_dpa_op4 blk15_dpa_op6 
                        (NamedAttr "callee" (SymbolRefAttr "Register::write"))))

(let blk15_dpa_ops (vec-of blk15_dpa_op0 blk15_dpa_op1 blk15_dpa_op2 blk15_dpa_op3 blk15_dpa_op4 blk15_dpa_op5 blk15_dpa_op6 blk15_dpa_op7))

;; ----------------------------------------------------------------------------
;; Block 15 Implementations - ONLY DPA and ARM (no DRMT)
;; ----------------------------------------------------------------------------

(implement blk15_dpa DPA (blk14) blk15_dpa_ops)
(implement blk15_cpu ARM (blk14) blk15_cpu_ops)

;; Block 15 Equivalences - only between DPA and ARM
(rewrite blk15_cpu blk15_dpa)

;; ============================================================================
;; Block 22: Metadata Update (INT node marking and switch ID assignment)
;; Valid on: DRMT, DPA, ARM
;; Dependencies: blk15
;; Description: Sets INT node bit and assigns switch_id to metadata
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 22 CPU (LLVM) - Metadata field updates via load/store
;; ----------------------------------------------------------------------------

;; Load metadata.int_node field
(let blk22_cpu_op0 (Value 1 (llvm_ptr)))
(let blk22_cpu_op1 (llvm_load blk22_cpu_op0 (llvm_struct "metadata" (Int 3) (Int 32) (Int 1))))
(let blk22_cpu_op2 (llvm_getelementptr blk22_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32))) (llvm_ptr)))
(let blk22_cpu_op3 (llvm_load blk22_cpu_op2 (Int 3)))

;; Create constant -4 (0b100 in 3-bit signed - sets high bit)
(let blk22_cpu_op4 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr -4 (Int 3))) (Int 3)))

;; OR operation to set INT bit
(let blk22_cpu_op5 (llvm_or blk22_cpu_op3 blk22_cpu_op4 (Int 3)))

;; Store back to metadata.int_node
(let blk22_cpu_op6 (llvm_store blk22_cpu_op5 blk22_cpu_op2))

;; Store switch_id (Value 2) to metadata.switch_id
(let blk22_cpu_op7 (llvm_getelementptr blk22_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32))) (llvm_ptr)))
(let blk22_cpu_op8 (llvm_store (Value 2 (Int 32)) blk22_cpu_op7))

(let blk22_cpu_ops (vec-of blk22_cpu_op0 blk22_cpu_op1 blk22_cpu_op2 blk22_cpu_op3 blk22_cpu_op4 blk22_cpu_op5 blk22_cpu_op6 blk22_cpu_op7 blk22_cpu_op8))

;; ----------------------------------------------------------------------------
;; Block 22 DPA - Metadata field updates via binop and assign
;; ----------------------------------------------------------------------------

;; Common metadata reference
(let blk22_dpa_op0 (Value 1 (bf3dpa_ref (bf3dpa_struct 
    (NamedAttr "name" (StringAttr "metadata")) 
    (NamedAttr "int_node" (TypeAttr (bf3dpa_bits 3))) 
    (NamedAttr "switch_id" (TypeAttr (bf3dpa_bits 32))) 
    (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1)))))))

;; Extract int_node field reference
(let blk22_dpa_op1 (bf3dpa_struct_extract_ref blk22_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3dpa_ref (bf3dpa_bits 3))))

;; Read current int_node value
(let blk22_dpa_op2 (bf3dpa_read blk22_dpa_op1 (bf3dpa_bits 3)))

;; Create constant -4 (set INT bit)
(let blk22_dpa_op3 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int -4 (bf3dpa_bits 3))) (bf3dpa_bits 3)))

;; OR operation (kind 8 = bitwise OR)
(let blk22_dpa_op4 (bf3dpa_binop blk22_dpa_op2 blk22_dpa_op3 (NamedAttr "kind" (IntegerAttr 8 (I32))) (bf3dpa_bits 3)))

;; Assign back to int_node
(let blk22_dpa_op5 (bf3dpa_assign blk22_dpa_op4 blk22_dpa_op1))

;; Extract switch_id field reference
(let blk22_dpa_op6 (bf3dpa_struct_extract_ref blk22_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3dpa_ref (bf3dpa_bits 32))))

;; Assign switch_id value (Value 2)
(let blk22_dpa_op7 (bf3dpa_assign (Value 2 (bf3dpa_bits 32)) blk22_dpa_op6))

(let blk22_dpa_ops (vec-of blk22_dpa_op0 blk22_dpa_op1 blk22_dpa_op2 blk22_dpa_op3 blk22_dpa_op4 blk22_dpa_op5 blk22_dpa_op6 blk22_dpa_op7))

;; ----------------------------------------------------------------------------
;; Block 22 DRMT - Metadata field updates using slice/concat (no bitwise OR)
;; ----------------------------------------------------------------------------

;; Common metadata reference
(let blk22_drmt_op0 (Value 1 (bf3drmt_ref (bf3drmt_struct 
    (NamedAttr "name" (StringAttr "metadata")) 
    (NamedAttr "int_node" (TypeAttr (bf3drmt_bits 3))) 
    (NamedAttr "switch_id" (TypeAttr (bf3drmt_bits 32))) 
    (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1)))))))

;; Extract int_node field reference
(let blk22_drmt_op1 (bf3drmt_struct_extract_ref blk22_drmt_op0 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3drmt_ref (bf3drmt_bits 3))))

;; Read current int_node value
(let blk22_drmt_op2 (bf3drmt_read blk22_drmt_op1 (bf3drmt_bits 3)))

;; Slice lower 2 bits [1:0]
(let blk22_drmt_op3 (bf3drmt_slice blk22_drmt_op2 (NamedAttr "highBit" (IntegerAttr 1 (I32))) (NamedAttr "lowBit" (IntegerAttr 0 (I32))) (bf3drmt_bits 2)))

;; Create constant 1 (set high bit)
(let blk22_drmt_op4 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 1 (bf3drmt_bits 1))) (bf3drmt_bits 1)))

;; Concatenate: 1 || lower_2_bits (sets bit 2 to 1)
(let blk22_drmt_op5 (bf3drmt_concat blk22_drmt_op4 blk22_drmt_op3 (bf3drmt_bits 3)))

;; Assign back to int_node
(let blk22_drmt_op6 (bf3drmt_assign blk22_drmt_op5 blk22_drmt_op1))

;; Extract switch_id field reference
(let blk22_drmt_op7 (bf3drmt_struct_extract_ref blk22_drmt_op0 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3drmt_ref (bf3drmt_bits 32))))

;; Assign switch_id value (Value 2)
(let blk22_drmt_op8 (bf3drmt_assign (Value 2 (bf3drmt_bits 32)) blk22_drmt_op7))

(let blk22_drmt_ops (vec-of blk22_drmt_op0 blk22_drmt_op1 blk22_drmt_op2 blk22_drmt_op3 blk22_drmt_op4 blk22_drmt_op5 blk22_drmt_op6 blk22_drmt_op7 blk22_drmt_op8))

;; ----------------------------------------------------------------------------
;; Block 22 Implementations - depends on blk15
;; ----------------------------------------------------------------------------

(implement blk22_drmt DRMT (blk15) blk22_drmt_ops)
(implement blk22_dpa DPA (blk15) blk22_dpa_ops)
(implement blk22_cpu ARM (blk15) blk22_dpa_ops)

;; Block 22 Equivalences
(rewrite blk22_cpu blk22_drmt)
(rewrite blk22_cpu blk22_dpa)