(let blk13_cpu_op9 (llvm_getelementptr blk13_cpu_op7 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 11) (I32))) (llvm_ptr)))
