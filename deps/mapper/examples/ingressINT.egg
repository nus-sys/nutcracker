;; ----------------------------------------------------------------------------
;; Block 13 DPA - Hash computation using multiplication
;; ----------------------------------------------------------------------------

;; Declare variables
(let blk13_dpa_op0 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_val")) (bf3dpa_ref (bf3dpa_bits 16))))
(let blk13_dpa_op1 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "srcIp")) (bf3dpa_ref (bf3dpa_bits 32))))
(let blk13_dpa_op2 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "MULT_HASH_A")) (bf3dpa_ref (bf3dpa_bits 32))))
