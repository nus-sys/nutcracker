;; ============================================================================
;; Hardware Configuration
;; ============================================================================

(hardware DRMT :cores 1 :sigma 0.0)
(hardware DPA :cores 190 :sigma 0.5)
(hardware ARM :cores 16 :sigma 1.0)

;; ============================================================================
;; Communication Links (BlueField-3 Topology)
;; ============================================================================

(link DRMT ARM 1.0 1.0)

;; ============================================================================
;; Operation Definitions (with costs and types)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; BF3 DRMT Dialect Operations (Hardware Dataplane - SRAM/TCAM)
;; ----------------------------------------------------------------------------

(function bf3drmt_variable (Type) Type :cost 1 :type stateless)
(function bf3drmt_read (Type) Type :cost 1 :type stateless)
(function bf3drmt_assign (Type) Type :cost 1 :type stateful :sigma 0.1)
(function bf3drmt_struct_extract_ref (Type) Type :cost 1 :type stateless)
(function bf3drmt_constant (Type) Type :cost 1 :type stateless)
(function bf3drmt_cast (Type) Type :cost 1 :type stateless)
(function bf3drmt_binop (Type) Type :cost 1 :type stateless)
(function bf3drmt_shl (Type) Type :cost 1 :type stateless)
(function bf3drmt_shr (Type) Type :cost 1 :type stateless)
(function bf3drmt_concat (Type) Type :cost 1 :type stateless)
(function bf3drmt_slice (Type) Type :cost 1 :type stateless)
(function bf3drmt_match_key (Type) Type :cost 1 :type stateless)
(function bf3drmt_bool () Type :cost 1 :type stateless)

;; ----------------------------------------------------------------------------
;; BF3 DPA Dialect Operations (NPU - Programmable Dataplane)
;; ----------------------------------------------------------------------------

(function bf3dpa_variable (Type) Type :cost 10 :type stateless)
(function bf3dpa_read (Type) Type :cost 20 :type stateless)
(function bf3dpa_assign (Type) Type :cost 10 :type stateful :sigma 1.0)
(function bf3dpa_struct_extract_ref (Type) Type :cost 10 :type stateless)
(function bf3dpa_constant (Type) Type :cost 5 :type stateless)
(function bf3dpa_cast (Type) Type :cost 5 :type stateless)
(function bf3dpa_binop (Type) Type :cost 20 :type stateless)
(function bf3dpa_shl (Type) Type :cost 20 :type stateless)
(function bf3dpa_shr (Type) Type :cost 20 :type stateless)
(function bf3dpa_slice (Type) Type :cost 20 :type stateless)
(function bf3dpa_cmp (Type) Type :cost 20 :type stateless)
(function bf3dpa_if (Type) Type :cost 20 :type stateless)
(function bf3dpa_yield (Type) Type :cost 5 :type stateless)
(function bf3dpa_bool () Type :cost 5 :type stateless)

;; ----------------------------------------------------------------------------
;; LLVM Dialect Operations (CPU/ARM)
;; ----------------------------------------------------------------------------
(function llvm_ptr () Type :cost 2 :type stateless)

;; ----------------------------------------------------------------------------
;; Arithmetic Operations
;; ----------------------------------------------------------------------------
(function llvm_add (Op Op Type) Op :cost 5 :type stateless)
(function llvm_sub (Op Op Type) Op :cost 5 :type stateless)
(function llvm_mul (Op Op Type) Op :cost 5 :type stateless)

;; ----------------------------------------------------------------------------
;; Bitwise Operations
;; ----------------------------------------------------------------------------
(function llvm_and (Op Op Type) Op :cost 5 :type stateless)
(function llvm_or (Op Op Type) Op :cost 5 :type stateless)
(function llvm_xor (Op Op Type) Op :cost 5 :type stateless)
(function llvm_shl (Op Op Type) Op :cost 5 :type stateless)
(function llvm_lshr (Op Op Type) Op :cost 5 :type stateless)
(function llvm_ashr (Op Op Type) Op :cost 5 :type stateless)

;; ----------------------------------------------------------------------------
;; Memory Operations
;; ----------------------------------------------------------------------------

;; Stack allocation - essentially free (just moves stack pointer)
(function llvm_alloca (AttrPair AttrPair Type) Op :cost 1 :type stateless)

;; Load from memory - 3-4 cycles if L1 hit, more if cache miss
(function llvm_load (Op Type) Op :cost 3 :type stateless)

;; Store to memory - 1-2 cycles (write-through), but may stall pipeline
(function llvm_store (Op Op) Op :cost 2 :type stateful :sigma 0.1)

;; Pointer arithmetic (GEP) - 1-2 cycles (simple address calculation)
(function llvm_getelementptr (Op AttrPair AttrPair Type) Op :cost 2 :type stateless)

(function llvm_mlir_constant (AttrPair Type) Op :cost 1 :type stateless)
(function llvm_icmp (Op Op AttrPair Type) Op :cost 2 :type stateless)
(function llvm_cond_br (Op AttrPair AttrPair) Op :cost 5 :type stateless)

;; ============================================================================
;; Block 2: Metadata Initialization
;; Valid on: DRMT, DPA, ARM
;; Dependencies: none
;; ============================================================================

;; Block 2 CPU (LLVM)
(let blk2_cpu_op0 (Value 1 (llvm_ptr)))
(let blk2_cpu_op1 (llvm_getelementptr blk2_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32))) (llvm_ptr)))
(let blk2_cpu_op2 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 0 (Int 3))) (Int 3)))
(let blk2_cpu_op3 (llvm_store blk2_cpu_op2 blk2_cpu_op1))
(let blk2_cpu_ops (vec-of blk2_cpu_op0 blk2_cpu_op1 blk2_cpu_op2 blk2_cpu_op3))

;; Block 2 DPA
(let blk2_dpa_op0 (Value 1 (bf3dpa_ref (bf3dpa_struct (NamedAttr "name" (StringAttr "metadata")) (NamedAttr "int_node" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "switch_id" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1)))))))
(let blk2_dpa_op1 (bf3dpa_struct_extract_ref blk2_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3dpa_ref (bf3dpa_bits 3))))
(let blk2_dpa_op2 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 0 (bf3dpa_bits 3))) (bf3dpa_bits 3)))
(let blk2_dpa_op3 (bf3dpa_cast blk2_dpa_op2 (bf3dpa_bits 3)))
(let blk2_dpa_op4 (bf3dpa_assign blk2_dpa_op3 blk2_dpa_op1))
(let blk2_dpa_ops (vec-of blk2_dpa_op0 blk2_dpa_op1 blk2_dpa_op2 blk2_dpa_op3 blk2_dpa_op4))

;; Block 2 DRMT
(let blk2_drmt_op0 (Value 1 (bf3drmt_ref (bf3drmt_struct (NamedAttr "name" (StringAttr "metadata")) (NamedAttr "int_node" (TypeAttr (bf3drmt_bits 3))) (NamedAttr "switch_id" (TypeAttr (bf3drmt_bits 32))) (NamedAttr "reserved1" (TypeAttr (bf3drmt_bits 1)))))))
(let blk2_drmt_op1 (bf3drmt_struct_extract_ref blk2_drmt_op0 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3drmt_ref (bf3drmt_bits 3))))
(let blk2_drmt_op2 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 0 (bf3drmt_bits 3))) (bf3drmt_bits 3)))
(let blk2_drmt_op3 (bf3drmt_cast blk2_drmt_op2 (bf3drmt_bits 3)))
(let blk2_drmt_op4 (bf3drmt_assign blk2_drmt_op3 blk2_drmt_op1))
(let blk2_drmt_ops (vec-of blk2_drmt_op0 blk2_drmt_op1 blk2_drmt_op2 blk2_drmt_op3 blk2_drmt_op4))

;; Block 2 Implementations
(implement blk2_drmt DRMT () blk2_drmt_ops)
(implement blk2_dpa DPA () blk2_dpa_ops)
(implement blk2_cpu ARM () blk2_cpu_ops)

;; Block 2 Equivalences
(rewrite blk2_cpu blk2_drmt)
(rewrite blk2_cpu blk2_dpa)

;; ============================================================================
;; Block 3: IPv4 Valid Check
;; Valid on: DRMT, DPA, ARM
;; Dependencies: blk2
;; ============================================================================

;; Block 3 CPU (LLVM) - conditional branch based on IPv4 validity
(let blk3_cpu_op0 (Value 0 (llvm_ptr)))
(let blk3_cpu_op1 (llvm_getelementptr blk3_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32))) (llvm_ptr)))
(let blk3_cpu_op2 (llvm_getelementptr blk3_cpu_op1 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 13) (I32))) (llvm_ptr)))
(let blk3_cpu_op3 (llvm_load blk3_cpu_op2 (I1)))
(let blk3_cpu_op4 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 1 (I1))) (I1)))
(let blk3_cpu_op5 (llvm_icmp blk3_cpu_op3 blk3_cpu_op4 (NamedAttr "predicate" (IntegerAttr 0 (I64))) (I1)))
(let blk3_cpu_op6 (llvm_cond_br blk3_cpu_op5 (NamedAttr "trueDest" (UnitAttr)) (NamedAttr "falseDest" (UnitAttr))))
(let blk3_cpu_ops (vec-of blk3_cpu_op0 blk3_cpu_op1 blk3_cpu_op2 blk3_cpu_op3 blk3_cpu_op4 blk3_cpu_op5 blk3_cpu_op6))

;; Block 3 DPA (simplified - use your full version)
(let blk3_dpa_op0 (Value 0 (bf3dpa_ref (bf3dpa_struct))))
(let blk3_dpa_op1 (bf3dpa_struct_extract_ref blk3_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3dpa_ref (bf3dpa_header))))
(let blk3_dpa_op2 (bf3dpa_struct_extract_ref blk3_dpa_op1 (NamedAttr "fieldIndex" (IntegerAttr 13 (I32))) (bf3dpa_ref (bf3dpa_valid_bit))))
(let blk3_dpa_op3 (bf3dpa_read blk3_dpa_op2 (bf3dpa_valid_bit)))
(let blk3_dpa_op4 (bf3dpa_constant (NamedAttr "value" (bf3dpa_validity_bit "valid" (bf3dpa_valid_bit))) (bf3dpa_valid_bit)))
(let blk3_dpa_op5 (bf3dpa_cmp blk3_dpa_op3 blk3_dpa_op4 (NamedAttr "kind" (IntegerAttr 5 (I32))) (bf3dpa_bool)))
(let blk3_dpa_op6 (bf3dpa_if blk3_dpa_op5 (Reg (vec-of (Blk (vec-of (bf3dpa_yield)))))))
(let blk3_dpa_ops (vec-of blk3_dpa_op0 blk3_dpa_op1 blk3_dpa_op2 blk3_dpa_op3 blk3_dpa_op4 blk3_dpa_op5 blk3_dpa_op6))

;; Block 3 DRMT (simplified - use your full version)
(let blk3_drmt_op0 (Value 0 (bf3drmt_ref (bf3drmt_struct))))
(let blk3_drmt_op1 (bf3drmt_struct_extract_ref blk3_drmt_op0 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3drmt_ref (bf3drmt_header))))
(let blk3_drmt_op2 (bf3drmt_struct_extract_ref blk3_drmt_op1 (NamedAttr "fieldIndex" (IntegerAttr 13 (I32))) (bf3drmt_ref (bf3drmt_valid_bit))))
(let blk3_drmt_op3 (bf3drmt_read blk3_drmt_op2 (bf3drmt_valid_bit)))
(let blk3_drmt_op4 (bf3drmt_constant (NamedAttr "value" (bf3drmt_validity_bit "valid" (bf3drmt_valid_bit))) (bf3drmt_valid_bit)))
(let blk3_drmt_op5 (bf3drmt_match_key blk3_drmt_op3 blk3_drmt_op4 (NamedAttr "kind" (IntegerAttr 5 (I32))) (bf3drmt_bool)))
(let blk3_drmt_ops (vec-of blk3_drmt_op0 blk3_drmt_op1 blk3_drmt_op2 blk3_drmt_op3 blk3_drmt_op4 blk3_drmt_op5))

;; Block 3 Implementations
(implement blk3_drmt DRMT (blk2) blk3_drmt_ops)
(implement blk3_dpa DPA (blk2) blk3_dpa_ops)
(implement blk3_cpu ARM (blk2) blk3_cpu_ops)

;; Block 3 Equivalences
(rewrite blk3_cpu blk3_drmt)
(rewrite blk3_cpu blk3_dpa)

;; ============================================================================
;; Block 6: Counter Value Check (counter_val >= 100)
;; Valid on: DRMT, DPA, ARM
;; Dependencies: blk3 (uses counter_val variable from earlier blocks)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 6 CPU (LLVM) - Corrected with llvm_alloca
;; ----------------------------------------------------------------------------

;; Allocate stack space for counter_val variable
(let blk6_cpu_op0 (llvm_alloca (NamedAttr "alignment" (IntegerAttr 4 (I64))) (llvm_ptr)))

;; Load the value from the allocated variable
(let blk6_cpu_op1 (llvm_load blk6_cpu_op0 (Int 16)))

;; Create constant 100
(let blk6_cpu_op2 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 100 (Int 16))) (Int 16)))

;; Compare: counter_val >= 100 (predicate 9 = unsigned greater-or-equal)
(let blk6_cpu_op3 (llvm_icmp blk6_cpu_op1 blk6_cpu_op2 (NamedAttr "predicate" (IntegerAttr 9 (I64))) (I1)))

;; Conditional branch based on comparison
(let blk6_cpu_op4 (llvm_cond_br blk6_cpu_op3 (NamedAttr "trueDest" (UnitAttr)) (NamedAttr "falseDest" (UnitAttr))))

(let blk6_cpu_ops (vec-of blk6_cpu_op0 blk6_cpu_op1 blk6_cpu_op2 blk6_cpu_op3 blk6_cpu_op4))

;; ----------------------------------------------------------------------------
;; Block 6 DPA (unchanged)
;; ----------------------------------------------------------------------------

(let blk6_dpa_op0 (bf3dpa_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_val")) (bf3dpa_ref (bf3dpa_bits 16))))
(let blk6_dpa_op1 (bf3dpa_read blk6_dpa_op0 (bf3dpa_bits 16)))
(let blk6_dpa_op2 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int 100 (bf3dpa_bits 16))) (bf3dpa_bits 16)))
(let blk6_dpa_op3 (bf3dpa_cmp blk6_dpa_op1 blk6_dpa_op2 (NamedAttr "kind" (IntegerAttr 4 (I32))) (bf3dpa_bool)))
(let blk6_dpa_op4 (bf3dpa_if blk6_dpa_op3 (Reg (vec-of (Blk (vec-of (bf3dpa_yield)))))))
(let blk6_dpa_ops (vec-of blk6_dpa_op0 blk6_dpa_op1 blk6_dpa_op2 blk6_dpa_op3 blk6_dpa_op4))

;; ----------------------------------------------------------------------------
;; Block 6 DRMT (unchanged)
;; ----------------------------------------------------------------------------

(let blk6_drmt_op0 (bf3drmt_variable (NamedAttr "init" (UnitAttr)) (NamedAttr "name" (StringAttr "counter_val")) (bf3drmt_ref (bf3drmt_bits 16))))
(let blk6_drmt_op1 (bf3drmt_read blk6_drmt_op0 (bf3drmt_bits 16)))
(let blk6_drmt_op2 (bf3drmt_constant (NamedAttr "value" (bf3drmt_int 100 (bf3drmt_bits 16))) (bf3drmt_bits 16)))
(let blk6_drmt_op3 (bf3drmt_match_key blk6_drmt_op1 blk6_drmt_op2 (NamedAttr "kind" (IntegerAttr 4 (I32))) (bf3drmt_bool)))
(let blk6_drmt_ops (vec-of blk6_drmt_op0 blk6_drmt_op1 blk6_drmt_op2 blk6_drmt_op3))

;; ----------------------------------------------------------------------------
;; Block 6 Implementations - depends on blk3
;; ----------------------------------------------------------------------------

(implement blk6_drmt DRMT (blk3) blk6_drmt_ops)
(implement blk6_dpa DPA (blk3) blk6_dpa_ops)
(implement blk6_cpu ARM (blk3) blk6_cpu_ops)

;; Block 6 Equivalences
(rewrite blk6_cpu blk6_drmt)
(rewrite blk6_cpu blk6_dpa)

;; ============================================================================
;; Block 8: MAC Address Swap and TTL Decrement
;; Valid on: DRMT, DPA, ARM
;; Dependencies: blk6
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 8 CPU (LLVM)
;; ----------------------------------------------------------------------------

;; Assign srcAddr (Value 2) to headers.ethernet.srcAddr
(let blk8_cpu_op0 (Value 0 (llvm_ptr)))
(let blk8_cpu_op1 (llvm_getelementptr blk8_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32))) (llvm_ptr)))
(let blk8_cpu_op2 (llvm_getelementptr blk8_cpu_op1 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32))) (llvm_ptr)))
(let blk8_cpu_op3 (llvm_store (Value 2 (Int 48)) blk8_cpu_op2))

;; Assign dstAddr (Value 3) to headers.ethernet.dstAddr
(let blk8_cpu_op4 (llvm_getelementptr blk8_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32))) (llvm_ptr)))
(let blk8_cpu_op5 (llvm_getelementptr blk8_cpu_op4 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 0) (I32))) (llvm_ptr)))
(let blk8_cpu_op6 (llvm_store (Value 3 (Int 48)) blk8_cpu_op5))

;; TTL decrement: load TTL, subtract 1, store back
(let blk8_cpu_op7 (llvm_getelementptr blk8_cpu_op0 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 1) (I32))) (llvm_ptr)))
(let blk8_cpu_op8 (llvm_getelementptr blk8_cpu_op7 (NamedAttr "inbounds" (UnitAttr)) (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of 0 8) (I32))) (llvm_ptr)))
(let blk8_cpu_op9 (llvm_load blk8_cpu_op8 (Int 8)))
(let blk8_cpu_op10 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 1 (Int 8))) (Int 8)))
(let blk8_cpu_op11 (llvm_sub blk8_cpu_op9 blk8_cpu_op10 (Int 8)))
(let blk8_cpu_op12 (llvm_store blk8_cpu_op11 blk8_cpu_op8))

(let blk8_cpu_ops (vec-of blk8_cpu_op0 blk8_cpu_op1 blk8_cpu_op2 blk8_cpu_op3 blk8_cpu_op4 blk8_cpu_op5 blk8_cpu_op6 blk8_cpu_op7 blk8_cpu_op8 blk8_cpu_op9 blk8_cpu_op10 blk8_cpu_op11 blk8_cpu_op12))

;; ----------------------------------------------------------------------------
;; Block 8 DPA
;; ----------------------------------------------------------------------------

;; Common headers reference
(let blk8_dpa_op0 (Value 0 (bf3dpa_ref (bf3dpa_struct (NamedAttr "name" (StringAttr "headers")) (NamedAttr "ethernet" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1)))))) (NamedAttr "ipv4" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32)))))) (NamedAttr "tcp" (TypeAttr (bf3dpa_header (NamedAttr "name" (StringAttr "tcp_t")) (NamedAttr "srcPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "dstPort" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "seqNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "ackNo" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dataOffset" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "res" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "window" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "checksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "urgentPtr" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))))))))))

;; Assign srcAddr: headers.ethernet.srcAddr = Value 2
(let blk8_dpa_op1 (bf3dpa_struct_extract_ref blk8_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3dpa_ref (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1)))))))
(let blk8_dpa_op2 (bf3dpa_struct_extract_ref blk8_dpa_op1 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3dpa_ref (bf3dpa_bits 48))))
(let blk8_dpa_op3 (bf3dpa_assign (Value 2 (bf3dpa_bits 48)) blk8_dpa_op2))

;; Assign dstAddr: headers.ethernet.dstAddr = Value 3
(let blk8_dpa_op4 (bf3dpa_struct_extract_ref blk8_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3dpa_ref (bf3dpa_header (NamedAttr "name" (StringAttr "ethernet_t")) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 48))) (NamedAttr "etherType" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "reserved1" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved2" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved3" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved4" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved5" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved6" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved7" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved8" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved9" (TypeAttr (bf3dpa_bits 1))) (NamedAttr "reserved10" (TypeAttr (bf3dpa_bits 1)))))))
(let blk8_dpa_op5 (bf3dpa_struct_extract_ref blk8_dpa_op4 (NamedAttr "fieldIndex" (IntegerAttr 0 (I32))) (bf3dpa_ref (bf3dpa_bits 48))))
(let blk8_dpa_op6 (bf3dpa_assign (Value 3 (bf3dpa_bits 48)) blk8_dpa_op5))

;; TTL decrement: headers.ipv4.ttl = headers.ipv4.ttl - 1
(let blk8_dpa_op7 (bf3dpa_struct_extract_ref blk8_dpa_op0 (NamedAttr "fieldIndex" (IntegerAttr 1 (I32))) (bf3dpa_ref (bf3dpa_header (NamedAttr "name" (StringAttr "ipv4_t")) (NamedAttr "version" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "ihl" (TypeAttr (bf3dpa_bits 4))) (NamedAttr "dscp" (TypeAttr (bf3dpa_bits 6))) (NamedAttr "ecn" (TypeAttr (bf3dpa_bits 2))) (NamedAttr "totalLen" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "identification" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "flags" (TypeAttr (bf3dpa_bits 3))) (NamedAttr "fragOffset" (TypeAttr (bf3dpa_bits 13))) (NamedAttr "ttl" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "protocol" (TypeAttr (bf3dpa_bits 8))) (NamedAttr "hdrChecksum" (TypeAttr (bf3dpa_bits 16))) (NamedAttr "srcAddr" (TypeAttr (bf3dpa_bits 32))) (NamedAttr "dstAddr" (TypeAttr (bf3dpa_bits 32)))))))
