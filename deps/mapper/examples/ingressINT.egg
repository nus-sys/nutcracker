(let blk13_cpu_op11 (llvm_store blk13_cpu_op10 blk13_cpu_op1))  ;; Store srcAddr to srcIp
(let blk13_cpu_op12 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 1234 (Int 32))) (Int 32)))
(let blk13_cpu_op13 (llvm_store blk13_cpu_op12 blk13_cpu_op2))
(let blk13_cpu_op14 (llvm_load blk13_cpu_op1 (Int 32)))  ;; Load srcIp
(let blk13_cpu_op15 (llvm_load blk13_cpu_op2 (Int 32)))  ;; Load MULT_HASH_A
(let blk13_cpu_op16 (llvm_mul blk13_cpu_op14 blk13_cpu_op15 (Int 32)))  ;; srcIp * MULT_HASH_A
(let blk13_cpu_op17 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 20 (Int 16))) (Int 16)))
(let blk13_cpu_op18 (llvm_lshr blk13_cpu_op16 blk13_cpu_op17 (Int 32)))  ;; >> 20
(let blk13_cpu_op19 (llvm_store blk13_cpu_op18 blk13_cpu_op3))  ;; Store to hash_val
(let blk13_cpu_op20 (llvm_load blk13_cpu_op3 (Int 32)))  ;; Load hash_val
(let blk13_cpu_op21 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 4095 (Int 32))) (Int 32)))
(let blk13_cpu_op22 (llvm_and blk13_cpu_op20 blk13_cpu_op21 (Int 32)))  ;; hash_val & 4095
