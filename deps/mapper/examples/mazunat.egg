;; ============================================================================
;; Hardware Configuration
;; ============================================================================

(hardware RX :cores 1 :sigma 0.0)
(hardware DRMT :cores 1 :sigma 0.0)
(hardware DPA :cores 190 :sigma 0.5)
(hardware ARM :cores 16 :sigma 1.0)

;; ============================================================================
;; Communication Links (BlueField-3 Topology)
;; ============================================================================

;; Input paths from RX
(link RX DRMT 0.0 1.0)
(link RX ARM 0.0 1.0)
(link RX DPA 20.0 0.5)

;; Inter-hardware links
(link DRMT ARM 1.0 1.0)

;; ============================================================================
;; Operation Definitions (with costs and types)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; BF3 DRMT Dialect Operations (Hardware Dataplane - SRAM/TCAM)
;; ----------------------------------------------------------------------------

(function bf3drmt_variable (Type) Type :cost 1 :type stateless)
(function bf3drmt_read (Type) Type :cost 1 :type stateless)
(function bf3drmt_assign (Type) Type :cost 1 :type stateful :sigma 0.1)
(function bf3drmt_struct_extract_ref (Type) Type :cost 1 :type stateless)
(function bf3drmt_constant (Type) Type :cost 1 :type stateless)
(function bf3drmt_cast (Type) Type :cost 1 :type stateless)
(function bf3drmt_match_key (Type Type Type Type) Type :cost 2 :type stateless)
(function bf3drmt_bool () Type :cost 1 :type stateless)
(function bf3drmt_valid_bit () Type :cost 1 :type stateless)
(function bf3drmt_bits (i64) Type :cost 1 :type stateless)
(function bf3drmt_ref (Type) Type :cost 1 :type stateless)
(function bf3drmt_struct (AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3drmt_header (AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3drmt_validity_bit (String Type) Attr :cost 1 :type stateless)

;; ----------------------------------------------------------------------------
;; BF3 DPA Dialect Operations (NPU - Programmable Dataplane)
;; ----------------------------------------------------------------------------

(function bf3dpa_variable (Type) Type :cost 8 :type stateless)
(function bf3dpa_read (Type) Type :cost 8 :type stateless)
(function bf3dpa_assign (Type) Type :cost 15 :type stateful :sigma 1.0)
(function bf3dpa_struct_extract_ref (Type) Type :cost 10 :type stateless)
(function bf3dpa_constant (Type) Type :cost 5 :type stateless)
(function bf3dpa_cast (Type) Type :cost 6 :type stateless)
(function bf3dpa_cmp (Type Type Type Type) Type :cost 12 :type stateless)
(function bf3dpa_if (Type Type) Type :cost 20 :type stateless)
(function bf3dpa_yield () Type :cost 2 :type stateless)
(function bf3dpa_bool () Type :cost 1 :type stateless)
(function bf3dpa_valid_bit () Type :cost 1 :type stateless)
(function bf3dpa_bits (i64) Type :cost 1 :type stateless)
(function bf3dpa_ref (Type) Type :cost 1 :type stateless)
(function bf3dpa_struct (AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3dpa_header (AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair AttrPair) Type :cost 1 :type stateless)
(function bf3dpa_validity_bit (String Type) Attr :cost 1 :type stateless)

;; ----------------------------------------------------------------------------
;; LLVM Dialect Operations (CPU/ARM)
;; ----------------------------------------------------------------------------

(function llvm_ptr () Type :cost 2 :type stateless)
(function llvm_mlir_constant (AttrPair Type) Op :cost 1 :type stateless)
(function llvm_load (Op Type) Op :cost 3 :type stateless)
(function llvm_getelementptr (Op AttrPair AttrPair Type) Op :cost 2 :type stateless)
(function llvm_icmp (Op Op AttrPair Type) Op :cost 2 :type stateless)
(function llvm_cond_br (Op AttrPair AttrPair) Op :cost 5 :type stateless)

;; ============================================================================
;; Block 0: Packet Field Comparison
;; Valid on: DRMT, DPA, ARM
;; Dependencies: None (first block)
;; Description: Compares packet field at offset [1][10] with constant 16885952
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 0 DRMT - Match key comparison
;; Pattern: match_key(packet.field, 16885952, exact)
;; Cost: 1 (struct_extract_ref) + 1 (read) + 1 (constant) + 2 (match_key) = 5
;; ----------------------------------------------------------------------------

;; Get reference to packet field at [1][10]
(let blk0_drmt_op0
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 10) (I32)))
        (bf3drmt_ref (bf3drmt_bool))))

;; Read the field value
(let blk0_drmt_op1
    (bf3drmt_read blk0_drmt_op0 (I32)))

;; Create constant 16885952 (0x01020000 in hex)
(let blk0_drmt_op2
    (bf3drmt_constant 
        (NamedAttr "value" (IntegerAttr 16885952 (I32)))
        (I32)))

;; Match key: exact match comparison
(let blk0_drmt_op3
    (bf3drmt_match_key 
        blk0_drmt_op1
        blk0_drmt_op2
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk0_drmt_ops (vec-of blk0_drmt_op0 blk0_drmt_op1 blk0_drmt_op2 blk0_drmt_op3))

;; ----------------------------------------------------------------------------
;; Block 0 DPA - Comparison operation
;; Pattern: cmp(packet.field, 16885952, eq)
;; Cost: 10 (struct_extract_ref) + 8 (read) + 5 (constant) + 12 (cmp) = 35
;; ----------------------------------------------------------------------------

;; Get reference to packet field at [1][10]
(let blk0_dpa_op0
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 10) (I32)))
        (bf3dpa_ref (bf3dpa_bool))))

;; Read the field value
(let blk0_dpa_op1
    (bf3dpa_read blk0_dpa_op0 (I32)))

;; Create constant 16885952 (0x01020000 in hex)
(let blk0_dpa_op2
    (bf3dpa_constant 
        (NamedAttr "value" (IntegerAttr 16885952 (I32)))
        (I32)))

;; Compare: field == 16885952 (predicate 0 = eq)
(let blk0_dpa_op3
    (bf3dpa_cmp 
        blk0_dpa_op1
        blk0_dpa_op2
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk0_dpa_ops (vec-of blk0_dpa_op0 blk0_dpa_op1 blk0_dpa_op2 blk0_dpa_op3))

;; ----------------------------------------------------------------------------
;; Block 0 ARM (LLVM) - Load and compare
;; Pattern: load packet.field; icmp eq, 16885952
;; Cost: 1 (constant 0) + 2 (gep) + 3 (load) + 1 (constant) + 2 (icmp) = 9
;; ----------------------------------------------------------------------------

;; Get packet pointer (Value 0)
(let blk0_cpu_op0 (Value 0 (llvm_ptr)))

;; Create constant 0 for GEP base
(let blk0_cpu_op1 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 0 (I64)))
        (I64)))

;; GEP to packet field at [0, 1, 10]
(let blk0_cpu_op2 
    (llvm_getelementptr blk0_cpu_op0 blk0_cpu_op1
        (NamedAttr "elem_type" (TypeAttr (llvm_struct "struct.packet" 
            (llvm_struct "struct.ethernet" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16))
            (llvm_struct "struct.ipv4" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16) (I32) (I32) (I32) (I32))
            (llvm_struct "struct.tcp" (I16) (I16) (I32) (I32) (I8) (I8) (I16) (I16) (I16) (I32) (I32) (I32) (I32))
            (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32))))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 10) (I32)))
        (llvm_ptr)))

;; Load field value
(let blk0_cpu_op3 
    (llvm_load blk0_cpu_op2 (I32)))

;; Create constant 16885952 for comparison
(let blk0_cpu_op4 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 16885952 (I32)))
        (I32)))

;; Compare: field == 16885952 (predicate 0 = eq)
(let blk0_cpu_op5 
    (llvm_icmp blk0_cpu_op3 blk0_cpu_op4
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk0_cpu_ops (vec-of blk0_cpu_op0 blk0_cpu_op1 blk0_cpu_op2 blk0_cpu_op3 blk0_cpu_op4 blk0_cpu_op5))

;; ============================================================================
;; Block 0 Deployment Declarations
;; ============================================================================

(implement blk0_drmt DRMT () blk0_drmt_ops)
(implement blk0_dpa DPA () blk0_dpa_ops)
(implement blk0_cpu ARM () blk0_cpu_ops)

;; Block 0 Equivalences
(rewrite blk0_cpu blk0_drmt)
(rewrite blk0_cpu blk0_dpa)


;; ============================================================================
;; Block 1: IPv4 Protocol Check (TCP)
;; Valid on: DRMT, DPA, ARM
;; Dependencies: block0 (IP address check passed)
;; Description: Checks if ipv4.protocol == 6 (TCP protocol)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 1 DRMT - Match key comparison
;; Pattern: match_key(ipv4.protocol, 6, exact)
;; Cost: 1 (struct_extract_ref) + 1 (read) + 1 (constant) + 2 (match_key) = 5
;; ----------------------------------------------------------------------------

;; Get reference to ipv4.protocol field at [1][7]
(let blk1_drmt_op0
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 7) (I32)))
        (bf3drmt_ref (bf3drmt_bool))))

;; Read the protocol field value
(let blk1_drmt_op1
    (bf3drmt_read blk1_drmt_op0 (I8)))

;; Create constant 6 (TCP protocol number)
(let blk1_drmt_op2
    (bf3drmt_constant 
        (NamedAttr "value" (IntegerAttr 6 (I8)))
        (I8)))

;; Match key: exact match for TCP protocol
(let blk1_drmt_op3
    (bf3drmt_match_key 
        blk1_drmt_op1
        blk1_drmt_op2
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk1_drmt_ops (vec-of blk1_drmt_op0 blk1_drmt_op1 blk1_drmt_op2 blk1_drmt_op3))

;; ----------------------------------------------------------------------------
;; Block 1 DPA - Comparison operation
;; Pattern: cmp(ipv4.protocol, 6, eq)
;; Cost: 10 (struct_extract_ref) + 8 (read) + 5 (constant) + 12 (cmp) = 35
;; ----------------------------------------------------------------------------

;; Get reference to ipv4.protocol field at [1][7]
(let blk1_dpa_op0
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 7) (I32)))
        (bf3dpa_ref (bf3dpa_bool))))

;; Read the protocol field value
(let blk1_dpa_op1
    (bf3dpa_read blk1_dpa_op0 (I8)))

;; Create constant 6 (TCP protocol number)
(let blk1_dpa_op2
    (bf3dpa_constant 
        (NamedAttr "value" (IntegerAttr 6 (I8)))
        (I8)))

;; Compare: protocol == 6
(let blk1_dpa_op3
    (bf3dpa_cmp 
        blk1_dpa_op1
        blk1_dpa_op2
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk1_dpa_ops (vec-of blk1_dpa_op0 blk1_dpa_op1 blk1_dpa_op2 blk1_dpa_op3))

;; ----------------------------------------------------------------------------
;; Block 1 ARM (LLVM) - Load and compare protocol field
;; Pattern: load ipv4.protocol; icmp eq, 6
;; Cost: 1 (constant 0) + 2 (gep) + 3 (load) + 1 (constant) + 2 (icmp) = 9
;; ----------------------------------------------------------------------------

;; Get packet pointer (Value 0)
(let blk1_cpu_op0 (Value 0 (llvm_ptr)))

;; Create constant 0 for GEP base
(let blk1_cpu_op1 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 0 (I64)))
        (I64)))

;; GEP to ipv4.protocol at [0, 1, 7]
(let blk1_cpu_op2 
    (llvm_getelementptr blk1_cpu_op0 blk1_cpu_op1
        (NamedAttr "elem_type" (TypeAttr (llvm_struct "struct.packet" 
            (llvm_struct "struct.ethernet" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16))
            (llvm_struct "struct.ipv4" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16) (I32) (I32) (I32) (I32))
            (llvm_struct "struct.tcp" (I16) (I16) (I32) (I32) (I8) (I8) (I16) (I16) (I16) (I32) (I32) (I32) (I32))
            (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32))))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 7) (I32)))
        (llvm_ptr)))

;; Load protocol field value
(let blk1_cpu_op3 
    (llvm_load blk1_cpu_op2 (I8)))

;; Create constant 6 (TCP protocol number)
(let blk1_cpu_op4 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 6 (I8)))
        (I8)))

;; Compare: protocol == 6
(let blk1_cpu_op5 
    (llvm_icmp blk1_cpu_op3 blk1_cpu_op4
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk1_cpu_ops (vec-of blk1_cpu_op0 blk1_cpu_op1 blk1_cpu_op2 blk1_cpu_op3 blk1_cpu_op4 blk1_cpu_op5))

;; ============================================================================
;; Block 1 Deployment Declarations
;; ============================================================================

(implement blk1_drmt DRMT (blk0) blk1_drmt_ops)
(implement blk1_dpa DPA (blk0) blk1_dpa_ops)
(implement blk1_cpu ARM (blk0) blk1_cpu_ops)

;; Block 1 Equivalences
(rewrite blk1_cpu blk1_drmt)
(rewrite blk1_cpu blk1_dpa)

