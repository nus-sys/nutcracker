            (llvm_struct "struct.ipv4" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16) (I32) (I32) (I32) (I32))
            (llvm_struct "struct.tcp" (I16) (I16) (I32) (I32) (I8) (I8) (I16) (I16) (I16) (I32) (I32) (I32) (I32))
            (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32))))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 2 1) (I32)))
        (llvm_ptr)))

;; Load destination port field value
(let blk3_cpu_op3 
    (llvm_load blk3_cpu_op2 (I16)))

;; Create constant 20480 (0x5000, port 80 big-endian = HTTP)
(let blk3_cpu_op4 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 20480 (I16)))
        (I16)))

;; Compare: dstPort == 20480
(let blk3_cpu_op5 
    (llvm_icmp blk3_cpu_op3 blk3_cpu_op4
        (NamedAttr "predicate" (IntegerAttr 0 (I64)))
        (I1)))

(let blk3_cpu_ops (vec-of blk3_cpu_op0 blk3_cpu_op1 blk3_cpu_op2 blk3_cpu_op3 blk3_cpu_op4 blk3_cpu_op5))

;; ============================================================================
;; Block 3 Deployment Declarations
;; ============================================================================

(implement blk3_drmt DRMT (blk2) blk3_drmt_ops)
(implement blk3_dpa DPA (blk2) blk3_dpa_ops)
(implement blk3_cpu ARM (blk2) blk3_cpu_ops)

;; Block 3 Equivalences
(rewrite blk3_cpu blk3_drmt)
(rewrite blk3_cpu blk3_dpa)

;; ============================================================================
;; Block 4: Packet Field Modification (Join Point)
;; Valid on: DRMT, DPA, ARM
;; Dependencies: block2 AND block3 (both port checks complete)
;; Description: Sets packet field [1][10] to 167772170 (0x0A000000 = IP 10.0.0.10)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 4 DRMT - Assign constant to field
;; Pattern: packet.field[1][10] = 167772170
;; Cost: 1 (struct_extract_ref) + 1 (constant) + 2 (assign) = 4
;; ----------------------------------------------------------------------------

;; Get reference to packet field at [1][10]
(let blk4_drmt_op0
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 10) (I32)))
        (bf3drmt_ref (bf3drmt_bool))))

;; Create constant 167772170 (0x0A000000 = IP address 10.0.0.10 in some byte order)
(let blk4_drmt_op1
    (bf3drmt_constant 
        (NamedAttr "value" (IntegerAttr 167772170 (I32)))
        (I32)))

;; Assign constant to field
(let blk4_drmt_op2
    (bf3drmt_assign blk4_drmt_op0 blk4_drmt_op1))

(let blk4_drmt_ops (vec-of blk4_drmt_op0 blk4_drmt_op1 blk4_drmt_op2))

;; ----------------------------------------------------------------------------
;; Block 4 DPA - Assign constant to field
;; Pattern: packet.field[1][10] = 167772170
;; Cost: 10 (struct_extract_ref) + 5 (constant) + 15 (assign) = 30
;; ----------------------------------------------------------------------------

;; Create constant 167772170 (0x0A000000 = IP address 10.0.0.10)
(let blk4_dpa_op0
    (bf3dpa_constant 
        (NamedAttr "value" (IntegerAttr 167772170 (I32)))
        (I32)))

;; Get reference to packet field at [1][10]
(let blk4_dpa_op1
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 10) (I32)))
        (bf3dpa_ref (bf3dpa_bool))))

;; Assign constant to field
(let blk4_dpa_op2
    (bf3dpa_assign blk4_dpa_op0 blk4_dpa_op1))

(let blk4_dpa_ops (vec-of blk4_dpa_op0 blk4_dpa_op1 blk4_dpa_op2))

;; ----------------------------------------------------------------------------
;; Block 4 ARM (LLVM) - Store constant to field
;; Pattern: store 167772170, &packet.field[1][10]
;; Cost: 1 (constant 0) + 2 (gep) + 1 (constant value) + 2 (store) = 6
;; ----------------------------------------------------------------------------

;; Get packet pointer (Value 0)
(let blk4_cpu_op0 (Value 0 (llvm_ptr)))

;; Create constant 0 for GEP base
(let blk4_cpu_op1 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 0 (I64)))
        (I64)))

;; GEP to packet field at [0, 1, 10]
(let blk4_cpu_op2 
    (llvm_getelementptr blk4_cpu_op0 blk4_cpu_op1
        (NamedAttr "elem_type" (TypeAttr (llvm_struct "struct.packet" 
            (llvm_struct "struct.ethernet" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16))
            (llvm_struct "struct.ipv4" (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16) (I32) (I32) (I32) (I32))
            (llvm_struct "struct.tcp" (I16) (I16) (I32) (I32) (I8) (I8) (I16) (I16) (I16) (I32) (I32) (I32) (I32))
            (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32) (I32))))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 3 (vec-of -2147483648 1 10) (I32)))
        (llvm_ptr)))

;; Create constant 167772170 (0x0A000000 = IP address 10.0.0.10)
(let blk4_cpu_op3 
    (llvm_mlir_constant 
        (NamedAttr "value" (IntegerAttr 167772170 (I32)))
        (I32)))

;; Store constant to field
(let blk4_cpu_op4 
    (llvm_store blk4_cpu_op3 blk4_cpu_op2))

(let blk4_cpu_ops (vec-of blk4_cpu_op0 blk4_cpu_op1 blk4_cpu_op2 blk4_cpu_op3 blk4_cpu_op4))

;; ============================================================================
;; Block 4 Deployment Declarations
;; ============================================================================

(implement blk4_drmt DRMT (blk2 blk3) blk4_drmt_ops)
(implement blk4_dpa DPA (blk2 blk3) blk4_dpa_ops)
(implement blk4_cpu ARM (blk2 blk3) blk4_cpu_ops)

;; Block 4 Equivalences
(rewrite blk4_cpu blk4_drmt)
(rewrite blk4_cpu blk4_dpa)

;; ============================================================================
;; Block 5: Ethernet Header Rewrite
;; Valid on: DRMT, DPA, ARM
;; Dependencies: block0, block1, block3, block4 (complex join point)
;; Description: Rewrites MAC addresses and sets EtherType to 0x0008 (IPv4)
;; ============================================================================

;; ----------------------------------------------------------------------------
;; Block 5 DRMT - Multiple field assignments
;; Pattern: Set MAC addresses and EtherType
;; Cost: 12×(1 constant + 2 assign) + 1 constant + 1 extract_ref + 2 assign = 40
;; ----------------------------------------------------------------------------

;; Destination MAC bytes (Values 8-13): 3C:FD:FE:9E:5D:01
(let blk5_drmt_op0 (bf3drmt_constant (NamedAttr "value" (IntegerAttr 60 (I8))) (I8)))
(let blk5_drmt_op1 (bf3drmt_constant (NamedAttr "value" (IntegerAttr -3 (I8))) (I8)))
(let blk5_drmt_op2 (bf3drmt_constant (NamedAttr "value" (IntegerAttr -2 (I8))) (I8)))
(let blk5_drmt_op3 (bf3drmt_constant (NamedAttr "value" (IntegerAttr -98 (I8))) (I8)))
(let blk5_drmt_op4 (bf3drmt_constant (NamedAttr "value" (IntegerAttr 93 (I8))) (I8)))
(let blk5_drmt_op5 (bf3drmt_constant (NamedAttr "value" (IntegerAttr 1 (I8))) (I8)))

;; Assign destination MAC bytes
(let blk5_drmt_op6 (bf3drmt_assign (Value 8 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op0))
(let blk5_drmt_op7 (bf3drmt_assign (Value 9 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op1))
(let blk5_drmt_op8 (bf3drmt_assign (Value 10 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op2))
(let blk5_drmt_op9 (bf3drmt_assign (Value 11 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op3))
(let blk5_drmt_op10 (bf3drmt_assign (Value 12 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op4))
(let blk5_drmt_op11 (bf3drmt_assign (Value 13 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op5))

;; Source MAC bytes (Values 22-27): 3C:FD:FE:9E:7D:21
(let blk5_drmt_op12 (bf3drmt_constant (NamedAttr "value" (IntegerAttr 125 (I8))) (I8)))
(let blk5_drmt_op13 (bf3drmt_constant (NamedAttr "value" (IntegerAttr 33 (I8))) (I8)))

;; Assign source MAC bytes
(let blk5_drmt_op14 (bf3drmt_assign (Value 22 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op0))
(let blk5_drmt_op15 (bf3drmt_assign (Value 23 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op1))
(let blk5_drmt_op16 (bf3drmt_assign (Value 24 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op2))
(let blk5_drmt_op17 (bf3drmt_assign (Value 25 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op3))
(let blk5_drmt_op18 (bf3drmt_assign (Value 26 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op12))
(let blk5_drmt_op19 (bf3drmt_assign (Value 27 (bf3drmt_ref (bf3drmt_bool))) blk5_drmt_op13))

;; EtherType field
(let blk5_drmt_op20
    (bf3drmt_struct_extract_ref 
        (Value 0 (bf3drmt_ref (bf3drmt_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of -2147483648 12) (I32)))
        (bf3drmt_ref (bf3drmt_bool))))

(let blk5_drmt_op21 (bf3drmt_constant (NamedAttr "value" (IntegerAttr 8 (I16))) (I16)))
(let blk5_drmt_op22 (bf3drmt_assign blk5_drmt_op20 blk5_drmt_op21))

(let blk5_drmt_ops (vec-of blk5_drmt_op0 blk5_drmt_op1 blk5_drmt_op2 blk5_drmt_op3 blk5_drmt_op4 blk5_drmt_op5 
                            blk5_drmt_op6 blk5_drmt_op7 blk5_drmt_op8 blk5_drmt_op9 blk5_drmt_op10 blk5_drmt_op11
                            blk5_drmt_op12 blk5_drmt_op13 blk5_drmt_op14 blk5_drmt_op15 blk5_drmt_op16 blk5_drmt_op17
                            blk5_drmt_op18 blk5_drmt_op19 blk5_drmt_op20 blk5_drmt_op21 blk5_drmt_op22))

;; ----------------------------------------------------------------------------
;; Block 5 DPA - Multiple field assignments
;; Cost: 12×(5 constant + 15 assign) + 5 + 10 + 15 = 270
;; ----------------------------------------------------------------------------

;; Destination MAC constants
(let blk5_dpa_op0 (bf3dpa_constant (NamedAttr "value" (IntegerAttr 60 (I8))) (I8)))
(let blk5_dpa_op1 (bf3dpa_constant (NamedAttr "value" (IntegerAttr -3 (I8))) (I8)))
(let blk5_dpa_op2 (bf3dpa_constant (NamedAttr "value" (IntegerAttr -2 (I8))) (I8)))
(let blk5_dpa_op3 (bf3dpa_constant (NamedAttr "value" (IntegerAttr -98 (I8))) (I8)))
(let blk5_dpa_op4 (bf3dpa_constant (NamedAttr "value" (IntegerAttr 93 (I8))) (I8)))
(let blk5_dpa_op5 (bf3dpa_constant (NamedAttr "value" (IntegerAttr 1 (I8))) (I8)))

;; Assign destination MAC
(let blk5_dpa_op6 (bf3dpa_assign blk5_dpa_op0 (Value 8 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op7 (bf3dpa_assign blk5_dpa_op1 (Value 9 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op8 (bf3dpa_assign blk5_dpa_op2 (Value 10 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op9 (bf3dpa_assign blk5_dpa_op3 (Value 11 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op10 (bf3dpa_assign blk5_dpa_op4 (Value 12 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op11 (bf3dpa_assign blk5_dpa_op5 (Value 13 (bf3dpa_ref (bf3dpa_bool)))))

;; Source MAC constants
(let blk5_dpa_op12 (bf3dpa_constant (NamedAttr "value" (IntegerAttr 125 (I8))) (I8)))
(let blk5_dpa_op13 (bf3dpa_constant (NamedAttr "value" (IntegerAttr 33 (I8))) (I8)))

;; Assign source MAC
(let blk5_dpa_op14 (bf3dpa_assign blk5_dpa_op0 (Value 22 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op15 (bf3dpa_assign blk5_dpa_op1 (Value 23 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op16 (bf3dpa_assign blk5_dpa_op2 (Value 24 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op17 (bf3dpa_assign blk5_dpa_op3 (Value 25 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op18 (bf3dpa_assign blk5_dpa_op12 (Value 26 (bf3dpa_ref (bf3dpa_bool)))))
(let blk5_dpa_op19 (bf3dpa_assign blk5_dpa_op13 (Value 27 (bf3dpa_ref (bf3dpa_bool)))))

;; EtherType
(let blk5_dpa_op20 (bf3dpa_constant (NamedAttr "value" (IntegerAttr 8 (I16))) (I16)))
(let blk5_dpa_op21
    (bf3dpa_struct_extract_ref 
        (Value 0 (bf3dpa_ref (bf3dpa_bool)))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of -2147483648 12) (I32)))
        (bf3dpa_ref (bf3dpa_bool))))
(let blk5_dpa_op22 (bf3dpa_assign blk5_dpa_op20 blk5_dpa_op21))

(let blk5_dpa_ops (vec-of blk5_dpa_op0 blk5_dpa_op1 blk5_dpa_op2 blk5_dpa_op3 blk5_dpa_op4 blk5_dpa_op5 
                          blk5_dpa_op6 blk5_dpa_op7 blk5_dpa_op8 blk5_dpa_op9 blk5_dpa_op10 blk5_dpa_op11
                          blk5_dpa_op12 blk5_dpa_op13 blk5_dpa_op14 blk5_dpa_op15 blk5_dpa_op16 blk5_dpa_op17
                          blk5_dpa_op18 blk5_dpa_op19 blk5_dpa_op20 blk5_dpa_op21 blk5_dpa_op22))

;; ----------------------------------------------------------------------------
;; Block 5 ARM (LLVM) - Store constants to MAC and EtherType fields
;; Cost: 6×(1 const) + 12×(2 store) + 1 const + 2 gep + 1 const + 2 store = 39
;; ----------------------------------------------------------------------------

;; Base pointer and constants
(let blk5_cpu_op0 (Value 0 (llvm_ptr)))
(let blk5_cpu_op1 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 0 (I64))) (I64)))

;; MAC address constants
(let blk5_cpu_op2 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 60 (I8))) (I8)))
(let blk5_cpu_op3 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr -3 (I8))) (I8)))
(let blk5_cpu_op4 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr -2 (I8))) (I8)))
(let blk5_cpu_op5 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr -98 (I8))) (I8)))
(let blk5_cpu_op6 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 93 (I8))) (I8)))
(let blk5_cpu_op7 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 1 (I8))) (I8)))

;; Store destination MAC (Values 8-13)
(let blk5_cpu_op8 (Value 8 (llvm_ptr)))
(let blk5_cpu_op9 (Value 9 (llvm_ptr)))
(let blk5_cpu_op10 (Value 10 (llvm_ptr)))
(let blk5_cpu_op11 (Value 11 (llvm_ptr)))
(let blk5_cpu_op12 (Value 12 (llvm_ptr)))
(let blk5_cpu_op13 (Value 13 (llvm_ptr)))

(let blk5_cpu_op14 (llvm_store blk5_cpu_op2 blk5_cpu_op8))
(let blk5_cpu_op15 (llvm_store blk5_cpu_op3 blk5_cpu_op9))
(let blk5_cpu_op16 (llvm_store blk5_cpu_op4 blk5_cpu_op10))
(let blk5_cpu_op17 (llvm_store blk5_cpu_op5 blk5_cpu_op11))
(let blk5_cpu_op18 (llvm_store blk5_cpu_op6 blk5_cpu_op12))
(let blk5_cpu_op19 (llvm_store blk5_cpu_op7 blk5_cpu_op13))

;; Source MAC constants
(let blk5_cpu_op20 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 125 (I8))) (I8)))
(let blk5_cpu_op21 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 33 (I8))) (I8)))

;; Store source MAC (Values 22-27)
(let blk5_cpu_op22 (Value 22 (llvm_ptr)))
(let blk5_cpu_op23 (Value 23 (llvm_ptr)))
(let blk5_cpu_op24 (Value 24 (llvm_ptr)))
(let blk5_cpu_op25 (Value 25 (llvm_ptr)))
(let blk5_cpu_op26 (Value 26 (llvm_ptr)))
(let blk5_cpu_op27 (Value 27 (llvm_ptr)))

(let blk5_cpu_op28 (llvm_store blk5_cpu_op2 blk5_cpu_op22))
(let blk5_cpu_op29 (llvm_store blk5_cpu_op3 blk5_cpu_op23))
(let blk5_cpu_op30 (llvm_store blk5_cpu_op4 blk5_cpu_op24))
(let blk5_cpu_op31 (llvm_store blk5_cpu_op5 blk5_cpu_op25))
(let blk5_cpu_op32 (llvm_store blk5_cpu_op20 blk5_cpu_op26))
(let blk5_cpu_op33 (llvm_store blk5_cpu_op21 blk5_cpu_op27))

;; EtherType field
(let blk5_cpu_op34
    (llvm_getelementptr blk5_cpu_op0 blk5_cpu_op1
        (NamedAttr "elem_type" (TypeAttr (llvm_struct "struct.ethernet"
            (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I8) (I16))))
        (NamedAttr "inbounds" (UnitAttr))
        (NamedAttr "rawConstantIndices" (DenseIntArrayAttr 2 (vec-of -2147483648 12) (I32)))
        (llvm_ptr)))

(let blk5_cpu_op35 (llvm_mlir_constant (NamedAttr "value" (IntegerAttr 8 (I16))) (I16)))
(let blk5_cpu_op36 (llvm_store blk5_cpu_op35 blk5_cpu_op34))

(let blk5_cpu_ops (vec-of blk5_cpu_op2 blk5_cpu_op3 blk5_cpu_op4 blk5_cpu_op5 blk5_cpu_op6 blk5_cpu_op7
                          blk5_cpu_op14 blk5_cpu_op15 blk5_cpu_op16 blk5_cpu_op17 blk5_cpu_op18 blk5_cpu_op19
                          blk5_cpu_op20 blk5_cpu_op21 blk5_cpu_op28 blk5_cpu_op29 blk5_cpu_op30 blk5_cpu_op31
                          blk5_cpu_op32 blk5_cpu_op33 blk5_cpu_op35 blk5_cpu_op36))

;; ============================================================================
;; Block 5 Deployment Declarations
;; ============================================================================

(implement blk5_drmt DRMT (blk0 blk1 blk3 blk4) blk5_drmt_ops)
(implement blk5_dpa DPA (blk0 blk1 blk3 blk4) blk5_dpa_ops)
(implement blk5_cpu ARM (blk0 blk1 blk3 blk4) blk5_cpu_ops)

;; Block 5 Equivalences
(rewrite blk5_cpu blk5_drmt)
(rewrite blk5_cpu blk5_dpa)