;; Read egress_port value
(let blk16_dpa_op1 (bf3dpa_read blk16_dpa_op0 (bf3dpa_bits 9)))

;; Create constant -1 (full mask for exact match)
(let blk16_dpa_op2 (bf3dpa_constant (NamedAttr "value" (bf3dpa_int -1 (bf3dpa_bits 32))) (bf3dpa_bits 32)))

;; Perform exact match
(let blk16_dpa_op3 (bf3dpa_match_key blk16_dpa_op1 blk16_dpa_op2 (NamedAttr "match_kind" (bf3dpa_match_kind "exact")) (bf3dpa_bits 32)))

